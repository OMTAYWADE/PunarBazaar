<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PunarBazaar</title>

<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

<style>
/* smooth scroll */
html { scroll-behavior: smooth; }
</style>

</head>

<body class="bg-gray-100 text-gray-800">

<!-- 🔵 NAVBAR -->

<header class="bg-white shadow-sm sticky top-0 z-50">
<div class="max-w-7xl mx-auto flex items-center justify-between p-4 gap-4">

<!-- Logo -->

<h1 class="text-xl font-bold text-indigo-600">
    PunarBazaar
</h1>

<!-- Search -->

<form action="/search" class="hidden md:flex flex-1 max-w-lg">
    <input name="q" placeholder="Search items..."
    class="w-full px-4 py-2 border rounded-l-lg focus:ring-2 focus:ring-indigo-500 outline-none">

```
<button class="bg-indigo-600 text-white px-4 rounded-r-lg hover:bg-indigo-700">
    Search
</button>
```

</form>

<!-- Auth -->

<div class="flex items-center gap-4 text-sm">

<% if(currentUser){ %> <span class="hidden sm:block text-gray-600">
Hi, <%= currentUser.name %> </span>

```
<a href="/profile" class="text-indigo-600 hover:underline">Profile</a>

<a href="/logout" class="text-red-500 hover:underline">Logout</a>
```

<% } else { %>

```
<a href="/login" class="text-indigo-600 hover:underline">Login</a>

<a href="/signUp"
class="bg-indigo-600 text-white px-3 py-1.5 rounded-lg hover:bg-indigo-700">
    Signup
</a>
```

<% } %>

</div>
</div>
</header>

<!-- 📱 MOBILE SEARCH -->

<div class="md:hidden p-3">
<form action="/search" class="flex">
    <input name="q" placeholder="Search..."
    class="w-full px-3 py-2 border rounded-l-lg">
    <button class="bg-indigo-600 text-white px-4 rounded-r-lg">
        Go
    </button>
</form>
</div>

<!-- CATEGORY -->

<div class="flex justify-center flex-wrap gap-4 text-sm py-3 bg-white shadow-sm">

<a href="/category/Books" class="hover:text-indigo-600">Books</a> <a href="/category/Electronics" class="hover:text-indigo-600">Electronics</a> <a href="/category/Notes" class="hover:text-indigo-600">Notes</a> <a href="/category/Instruments" class="hover:text-indigo-600">Instruments</a> <a href="/category/Others" class="hover:text-indigo-600">Others</a>

</div>

<!-- 🌟 HERO -->

<section class="max-w-7xl mx-auto mt-6 px-4">
<div class="bg-gradient-to-r from-indigo-600 via-purple-600 to-indigo-700 text-white rounded-2xl p-8 shadow-lg">

<h2 class="text-2xl md:text-3xl font-bold">
    Buy & Sell within your College
</h2>

<p class="mt-2 opacity-90 text-sm md:text-base">
    Books, notes, electronics & more — safe and trusted marketplace
</p>

<a href="/addItems"
class="inline-block mt-5 bg-white text-indigo-600 px-5 py-2 rounded-lg font-medium hover:scale-105 transition">
Start Selling 🚀 </a>

</div>
</section>

<!-- HEADER -->

<div class="max-w-7xl mx-auto mt-8 px-4 flex justify-between items-center">

<h2 class="text-xl font-semibold">
    Explore Items
</h2>

<a href="/addItems"
class="bg-indigo-600 text-white px-4 py-2 rounded-lg hover:bg-indigo-700">
+ Add Item </a>

</div>

<!-- 🧱 GRID -->

<section class="max-w-7xl mx-auto mt-6 px-4 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-6">

<% items.forEach(item => { %>

<div class="bg-white rounded-xl shadow-sm hover:shadow-xl transition overflow-hidden group">

<!-- IMAGE -->

<div class="h-40 bg-gray-200 relative overflow-hidden">

<% if(item.image){ %> <img src="<%= item.image %>" 
class="w-full h-full object-cover group-hover:scale-105 transition duration-300">
<% } else { %>

<div class="flex items-center justify-center h-full text-gray-400 text-sm">
    No Image
</div>
<% } %>

<!-- Wishlist -->

<a href="/wishlist/add/<%= item._id %>"
class="absolute top-2 right-2 bg-white p-2 rounded-full shadow hover:scale-110">
❤️ </a>

</div>

<!-- CONTENT -->

<div class="p-4">

<h2 class="text-sm font-semibold truncate">
<%= item.name %>
</h2>

<p class="text-green-600 font-bold mt-1">
₹ <%= item.price %>
</p>

<p class="text-xs text-gray-500 mt-1 truncate">
<%= item.user?.college || "Unknown College" %>
</p>

<a href="/item/<%= item._id %>"
class="block mt-3 text-center bg-indigo-600 text-white py-1.5 rounded-lg text-sm hover:bg-indigo-700">
View Details </a>

</div>

</div>

<% }) %>

</section>

<!-- FOOTER -->

<footer class="mt-10 bg-white border-t py-6 text-center text-sm text-gray-500">
© 2026 PunarBazaar — Built for Students ❤️
</footer>

</body>
</html>
