<% items.forEach(item => { %>

<div class="bg-white rounded-lg shadow hover:shadow-lg transition overflow-hidden">

```
<!-- Image -->
<div class="h-40 bg-gray-200 flex items-center justify-center overflow-hidden">
    <div class="hover:scale-110 transition duration-300 w-full h-full flex items-center justify-center">
        <span class="text-gray-400 text-sm">Image</span>
    </div>
</div>

<div class="p-3">

    <!-- Title -->
    <h2 class="text-sm font-semibold truncate">
        <%= item.name %>
    </h2>

    <!-- Price -->
    <p class="text-green-600 font-bold text-sm">
        ₹ <%= item.price %>
    </p>

    <!-- College -->
    <p class="text-xs text-gray-500">
        <%= item.user?.college || "Unknown" %>
    </p>

    <!-- Badge -->
    <% if(item.isFeatured){ %>
        <span class="text-yellow-500 text-xs">⚡ Featured</span>
    <% } %>

    <!-- Actions -->
    <div class="flex justify-between items-center mt-2 text-xs">

        <a href="/wishlist/add/<%= item._id %>"
        class="text-pink-500 hover:scale-110 transition">
            ❤️
        </a>

        <a href="/item/<%= item._id %>"
        class="bg-blue-500 text-white px-2 py-1 rounded hover:bg-blue-600 transition">
            View
        </a>

    </div>

</div>
```

</div>

