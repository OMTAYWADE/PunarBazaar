<!-- 🔵 NAVBAR -->

<div class="bg-white shadow sticky top-0 z-50">

```
<div class="max-w-6xl mx-auto flex items-center justify-between p-3">

    <!-- Logo -->
    <h1 class="text-xl font-bold text-blue-600">
        🛍️ PunarBazaar
    </h1>

    <!-- Search -->
    <form action="/search" class="flex w-1/2">
        <input name="q" placeholder="Search for products..."
        class="w-full p-2 border rounded-l outline-none">

        <button class="bg-blue-600 text-white px-4 rounded-r">
            🔍
        </button>
    </form>

    <!-- Auth -->
    <div class="flex gap-3 items-center">

        <% if(currentUser){ %>
            <span class="text-sm">Hi, <%= currentUser.name %></span>
            <a href="/profile" class="text-blue-600">Profile</a>
            <a href="/logout" class="text-red-500">Logout</a>
        <% } else { %>
            <a href="/login" class="text-blue-600">Login</a>
            <a href="/signUp" class="bg-blue-600 text-white px-3 py-1 rounded">
                Signup
            </a>
        <% } %>

    </div>

</div>

<!-- CATEGORY -->
<div class="bg-gray-50 border-t flex justify-center gap-6 p-2 text-sm">

    <a href="/category/Books" class="hover:text-blue-600">Books</a>
    <a href="/category/Electronics" class="hover:text-blue-600">Electronics</a>
    <a href="/category/Notes" class="hover:text-blue-600">Notes</a>
    <a href="/category/Instruments" class="hover:text-blue-600">Instruments</a>
    <a href="/category/Others" class="hover:text-blue-600">Others</a>

</div>
```

</div>

