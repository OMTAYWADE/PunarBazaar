<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PunarBazaar</title>
<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-gradient-to-br from-indigo-50 via-purple-50 to-pink-50 min-h-screen">

<!-- 🔵 NAVBAR -->

<div class="bg-white shadow sticky top-0 z-50">

<div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between p-3 gap-3">

    <!-- Logo -->
    <h1 class="text-xl font-bold text-indigo-600">
        ⚡ PunarBazaar
    </h1>

    <!-- Search -->
    <form action="/search" class="flex w-full md:w-1/2">
        <input name="q" placeholder="Search items..."
        class="w-full p-2 border rounded-l outline-none">

        <button class="bg-indigo-600 text-white px-4 rounded-r">
            🔍
        </button>
    </form>

    <!-- Auth -->
    <div class="flex gap-3 items-center text-sm">

        <% if(currentUser){ %>
            <span class="text-gray-700">Hi, <%= currentUser.name %></span>
            <a href="/profile" class="text-indigo-600">Profile</a>
            <a href="/logout" class="text-red-500">Logout</a>
        <% } else { %>
            <a href="/login" class="text-indigo-600">Login</a>
            <a href="/signUp" class="bg-indigo-600 text-white px-3 py-1 rounded">
                Signup
            </a>
        <% } %>

    </div>

</div>

<!-- CATEGORY BAR -->
<div class="flex flex-wrap justify-center gap-4 text-sm p-2 text-gray-600 border-t">

    <a href="/category/Books" class="hover:text-indigo-600">Books</a>
    <a href="/category/Electronics" class="hover:text-indigo-600">Electronics</a>
    <a href="/category/Notes" class="hover:text-indigo-600">Notes</a>
    <a href="/category/Instruments" class="hover:text-indigo-600">Instruments</a>
    <a href="/category/Others" class="hover:text-indigo-600">Others</a>

</div>

</div>

<!-- HEADER -->

<div class="max-w-7xl mx-auto mt-6 px-4 flex flex-col sm:flex-row justify-between items-center gap-3">

<h2 class="text-xl font-semibold text-gray-700">
    🔥 Explore Items
</h2>

<a href="/addItems"
class="bg-gradient-to-r from-indigo-500 to-purple-500 text-white px-4 py-2 rounded-lg shadow hover:scale-105 transition">
    + Add Item
</a>

</div>

<!-- 🧱 GRID -->

<div class="max-w-7xl mx-auto mt-5 px-4 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-5">

<% items.forEach(item => { %>

<div class="bg-white rounded-2xl shadow-md hover:shadow-xl transition duration-300 overflow-hidden group relative">

<!-- IMAGE -->
<div class="h-40 bg-gradient-to-br from-gray-100 to-gray-200 flex items-center justify-center relative overflow-hidden">

    <div class="group-hover:scale-110 transition duration-300">
        <span class="text-gray-400 text-sm">Image</span>
    </div>

    <!-- Wishlist -->
    <a href="/wishlist/add/<%= item._id %>"
    class="absolute top-2 right-2 bg-white p-1 rounded-full shadow hover:scale-110 transition">
        ❤️
    </a>

</div>

<!-- CONTENT -->
<div class="p-3">

    <!-- TITLE -->
    <h2 class="text-sm font-semibold truncate text-gray-800">
        <%= item.name %>
    </h2>

    <!-- PRICE -->
    <p class="text-emerald-600 font-bold text-sm">
        ₹ <%= item.price %>
    </p>

    <!-- COLLEGE -->
    <p class="text-xs text-gray-500">
        🏫 <%= item.user?.college || "Unknown College" %>
    </p>

    <!-- FEATURED -->
    <% if(item.isFeatured){ %>
        <span class="text-xs text-purple-600">⚡ Featured</span>
    <% } %>

    <!-- SAME COLLEGE -->
    <% if(currentUser && item.user?.college === currentUser.college){ %>
        <p class="text-xs text-green-600 font-semibold">
            Same College 🎓
        </p>
    <% } %>

    <!-- BUTTON -->
    <a href="/item/<%= item._id %>"
    class="block text-center mt-2 bg-indigo-500 text-white py-1 rounded hover:bg-indigo-600 transition text-sm">
        View Details
    </a>

</div>

</div>

<% }) %>

</div>

</body>
</html>
