<div class="max-w-7xl mx-auto mt-5 px-4 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-6">

<% items.forEach(item => { %>

<div class="relative rounded-xl overflow-hidden group transition duration-300 
bg-gradient-to-br from-slate-900 to-slate-800 text-white 
shadow-md hover:shadow-2xl">

```
<!-- GLOW -->
<div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition 
bg-gradient-to-r from-indigo-500/10 via-purple-500/10 to-pink-500/10 blur-xl"></div>

<!-- IMAGE -->
<div class="h-44 bg-slate-800 flex items-center justify-center relative overflow-hidden">

    <% if(item.image){ %>
        <img src="<%= item.image %>" 
        class="w-full h-full object-cover group-hover:scale-110 transition duration-300">
    <% } else { %>
        <span class="text-gray-400 text-sm">No Image</span>
    <% } %>

    <!-- ❤️ Wishlist -->
    <button onclick="toggleWishlist(this, '<%= item._id %>')"
    class="absolute top-2 right-2 bg-white/10 backdrop-blur p-2 rounded-full 
    hover:scale-110 transition">

        <span class="heart text-white text-sm">♡</span>

    </button>

</div>

<!-- CONTENT -->
<div class="p-3 relative z-10">

    <!-- TITLE -->
    <h2 class="text-sm font-semibold truncate">
        <%= item.name %>
    </h2>

    <!-- PRICE -->
    <p class="text-emerald-400 font-bold text-sm mt-1">
        ₹ <%= item.price %>
    </p>

    <!-- COLLEGE -->
    <p class="text-xs text-gray-400 mt-1">
        <%= item.user?.college || "Unknown College" %>
    </p>

    <!-- BADGES -->
    <div class="flex gap-2 mt-2 flex-wrap">

        <% if(currentUser && item.user?.college === currentUser.college){ %>
            <span class="text-xs bg-green-500/20 text-green-400 px-2 py-0.5 rounded">
                Same College
            </span>
        <% } %>

        <% if(item.isFeatured){ %>
            <span class="text-xs bg-indigo-500/20 text-indigo-400 px-2 py-0.5 rounded">
                Featured
            </span>
        <% } %>

    </div>

    <!-- BUTTON -->
    <a href="/item/<%= item._id %>"
    class="block text-center mt-3 bg-indigo-600 text-white py-1.5 rounded-lg text-sm hover:bg-indigo-700 transition">
        View Details
    </a>

</div>
```

</div>

<% }) %>

</div>

<!-- ❤️ SCRIPT -->

<script>
function toggleWishlist(btn, itemId) {
    const heart = btn.querySelector(".heart");

    if (heart.innerText === "♡") {
        heart.innerText = "❤️";
        heart.classList.add("text-red-500");
    } else {
        heart.innerText = "♡";
        heart.classList.remove("text-red-500");
    }

    // Optional: call backend
    fetch("/wishlist/toggle/" + itemId, { method: "POST" });
}
</script>
