<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PunarBazaar</title>
<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-gray-50 min-h-screen">

<!-- 🔵 NAVBAR -->

<div class="bg-white border-b sticky top-0 z-50">

<div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between p-4 gap-3">

```
<!-- Logo -->
<h1 class="text-xl font-bold text-indigo-600">
    PunarBazaar
</h1>

<!-- Search -->
<form action="/search" class="flex w-full md:w-1/2">
    <input name="q" placeholder="Search items..."
    class="w-full p-2 border border-gray-300 rounded-l outline-none focus:ring-2 focus:ring-indigo-500">

    <button class="bg-indigo-600 text-white px-4 rounded-r hover:bg-indigo-700 transition">
        Search
    </button>
</form>

<!-- Auth -->
<div class="flex gap-3 items-center text-sm">

    <% if(currentUser){ %>
        <span class="text-gray-600">Hi, <%= currentUser.name %></span>
        <a href="/profile" class="text-indigo-600 font-medium">Profile</a>
        <a href="/logout" class="text-red-500">Logout</a>
    <% } else { %>
        <a href="/login" class="text-indigo-600">Login</a>
        <a href="/signUp" class="bg-indigo-600 text-white px-3 py-1 rounded">
            Signup
        </a>
    <% } %>

</div>
```

</div>

<!-- CATEGORY -->

<div class="flex justify-center gap-6 text-sm py-2 text-gray-600 border-t">

```
<a href="/category/Books" class="hover:text-indigo-600">Books</a>
<a href="/category/Electronics" class="hover:text-indigo-600">Electronics</a>
<a href="/category/Notes" class="hover:text-indigo-600">Notes</a>
<a href="/category/Instruments" class="hover:text-indigo-600">Instruments</a>
<a href="/category/Others" class="hover:text-indigo-600">Others</a>
```

</div>

</div>

<!-- 🌟 HERO -->

<div class="max-w-7xl mx-auto mt-6 px-4">

<div class="bg-gradient-to-r from-indigo-600 to-purple-600 text-white rounded-xl p-6">

```
<h2 class="text-2xl font-bold">
    Buy & Sell within your College
</h2>

<p class="text-sm mt-2 opacity-90">
    Books, notes, electronics & more — trusted student marketplace
</p>

<a href="/addItems"
class="inline-block mt-4 bg-white text-indigo-600 px-4 py-2 rounded font-medium hover:scale-105 transition">
    Start Selling
</a>
```

</div>

</div>

<!-- HEADER -->

<div class="max-w-7xl mx-auto mt-6 px-4 flex justify-between items-center">

<h2 class="text-lg font-semibold text-gray-800">
    Explore Items
</h2>

<a href="/addItems"
class="bg-indigo-600 text-white px-4 py-2 rounded hover:bg-indigo-700 transition">

* Add Item

  </a>

</div>

<!-- 🧱 GRID -->

<div class="max-w-7xl mx-auto mt-5 px-4 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-6">

<% items.forEach(item => { %>

<div class="bg-white border rounded-xl overflow-hidden hover:shadow-lg transition">

```
<!-- IMAGE -->
<div class="h-40 bg-gray-100 flex items-center justify-center relative">

    <% if(item.image){ %>
        <img src="<%= item.image %>" class="w-full h-full object-cover">
    <% } else { %>
        <span class="text-gray-400 text-sm">No Image</span>
    <% } %>

    <!-- Wishlist -->
    <a href="/wishlist/add/<%= item._id %>"
    class="absolute top-2 right-2 bg-white p-1 rounded-full shadow hover:scale-110 transition">
        ❤️
    </a>

</div>

<!-- CONTENT -->
<div class="p-3">

    <h2 class="text-sm font-medium text-gray-800 truncate">
        <%= item.name %>
    </h2>

    <p class="text-green-600 font-semibold text-sm mt-1">
        ₹ <%= item.price %>
    </p>

    <p class="text-xs text-gray-500 mt-1">
        <%= item.user?.college || "Unknown College" %>
    </p>

    <a href="/item/<%= item._id %>"
    class="block text-center mt-2 bg-indigo-600 text-white py-1 rounded text-sm hover:bg-indigo-700 transition">
        View Details
    </a>

</div>
```

</div>

<% }) %>

</div>

</body>
</html>
