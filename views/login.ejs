<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Login - PunarBazaar</title>

<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

<style>
@keyframes fadeUp {
  from { opacity:0; transform: translateY(25px); }
  to { opacity:1; transform: translateY(0); }
}

@keyframes slideIn {
  from { transform: translateX(120%); opacity: 0; }
  to { transform: translateX(0); opacity: 1; }
}

.animate-fadeUp { animation: fadeUp 0.6s ease forwards; }
.animate-slideIn { animation: slideIn 0.4s ease; }

/* glow */
.glow {
  box-shadow: 0 0 60px rgba(99,102,241,0.25);
}
</style>
</head>

<body class="min-h-screen flex items-center justify-center 
bg-gradient-to-br from-slate-900 via-indigo-900 to-slate-800 overflow-hidden text-white">

<!-- BACKGROUND -->
<div class="absolute inset-0 pointer-events-none">
    <div class="absolute w-80 h-80 bg-indigo-500/30 rounded-full blur-3xl top-10 left-10"></div>
    <div class="absolute w-80 h-80 bg-purple-500/30 rounded-full blur-3xl bottom-10 right-10"></div>
</div>

<!-- CARD -->
<div class="relative w-[92%] max-w-md bg-white/10 backdrop-blur-2xl 
border border-white/10 rounded-3xl shadow-2xl p-8 animate-fadeUp glow">

    <!-- LOGO -->
    <h1 class="text-2xl font-bold text-center tracking-wide 
    bg-gradient-to-r from-indigo-400 to-purple-400 bg-clip-text text-transparent">
        PunarBazaar
    </h1>

    <p class="text-center text-indigo-200 text-sm mt-2 mb-6">
        Welcome back 👋
    </p>

    <!-- FORM -->
    <form id="loginForm" class="space-y-5">

        <div>
            <label class="text-sm text-indigo-200">Email</label>
            <input name="email" required
            class="w-full mt-1 p-3 rounded-xl bg-white/10 border border-white/10
            focus:ring-2 focus:ring-indigo-400 outline-none transition">
        </div>

        <div>
            <label class="text-sm text-indigo-200">Password</label>
            <input name="password" type="password" required
            class="w-full mt-1 p-3 rounded-xl bg-white/10 border border-white/10
            focus:ring-2 focus:ring-indigo-400 outline-none transition">
        </div>

        <button id="btn"
        class="w-full py-3 rounded-xl font-medium
        bg-gradient-to-r from-indigo-600 to-purple-500
        hover:scale-[1.03] active:scale-[0.96]
        transition shadow-lg">
            Login
        </button>

    </form>

    <!-- FOOTER -->
    <p class="text-center text-sm text-indigo-200 mt-6">
        Don’t have an account?
        <a href="/signUp" class="text-indigo-400 font-semibold hover:underline">
            Sign up
        </a>
    </p>

</div>

<!-- LOADER -->
<div id="loader" class="fixed inset-0 bg-black/50 backdrop-blur flex items-center justify-center hidden">
    <div class="text-center">
        <div class="w-8 h-8 border-2 border-indigo-400 border-t-transparent rounded-full animate-spin mx-auto mb-3"></div>
        <p class="text-indigo-300">Logging in...</p>
    </div>
</div>

<!-- ERROR -->
<div id="errorBox" class="fixed top-5 right-5 hidden z-50">
    <div class="bg-red-500 text-white px-5 py-3 rounded-xl shadow-lg flex items-center gap-2 animate-slideIn">
        ❌ <span id="errorText"></span>
    </div>
</div>

<script>
const form = document.getElementById("loginForm");
const loader = document.getElementById("loader");
const btn = document.getElementById("btn");

form.addEventListener("submit", async (e) => {
    e.preventDefault();

    loader.classList.remove("hidden");
    btn.disabled = true;

    const formData = new FormData(form);

    try {
        const res = await fetch("/login", {
            method: "POST",
            body: new URLSearchParams(formData),
            credentials: "include"
        });

        const data = await res.json();

        if (!res.ok || !data.success) {
            showError(data.message || "Login failed");
            loader.classList.add("hidden");
            btn.disabled = false;
            return;
        }

        window.location.href = "/";

    } catch (err) {
        showError("Something went wrong");
        loader.classList.add("hidden");
        btn.disabled = false;
    }
});

function showError(message) {
    const box = document.getElementById("errorBox");
    const text = document.getElementById("errorText");

    text.innerText = message;
    box.classList.remove("hidden");

    setTimeout(() => box.classList.add("hidden"), 3000);
}
</script>

</body>
</html>