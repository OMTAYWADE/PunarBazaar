<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Login</title>
<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-gray-50 min-h-screen flex items-center justify-center">

<!-- MAIN CARD -->

<div class="bg-white p-6 rounded-lg shadow-sm border w-[90%] max-w-sm">

<!-- TITLE -->
<h1 class="text-xl font-semibold text-center text-gray-800 mb-2">
    Login to your account
</h1>

<p class="text-center text-gray-500 text-sm mb-5">
    Access your marketplace account
</p>

<!-- FORM -->
<form action="/login" method="POST" id="loginForm">

    <!-- EMAIL -->
    <div class="mb-3">
        <label class="text-sm text-gray-600">Email</label>
        <input name="email"
        class="w-full p-2 border rounded focus:ring-2 focus:ring-indigo-400 outline-none">
    </div>

    <!-- PASSWORD -->
    <div class="mb-4">
        <label class="text-sm text-gray-600">Password</label>
        <input name="password" type="password"
        class="w-full p-2 border rounded focus:ring-2 focus:ring-indigo-400 outline-none">
    </div>

    <!-- BUTTON -->
    <button class="bg-indigo-600 text-white w-full py-2 rounded hover:bg-indigo-700 transition">
        Login
    </button>

</form>

<!-- FOOTER -->
<p class="text-center text-xs text-gray-500 mt-4">
    Don’t have an account? 
    <a href="/signUp" class="text-indigo-600 font-medium">Sign up</a>
</p>

</div>

<!-- LOADER -->

<div id="loader" class="fixed inset-0 bg-white hidden flex items-center justify-center">
    <p class="text-indigo-600">Logging in...</p>
</div>

<script>
document.getElementById("loginForm").addEventListener("submit", () => {
    document.getElementById("loader").classList.remove("hidden");
});
</script>

</body>
</html>
