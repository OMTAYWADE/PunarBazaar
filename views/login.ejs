<!DOCTYPE html>
<html>
<head>
<title>Login</title>
<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-black text-white flex items-center justify-center h-screen">

<!-- ⚡ LOADER (Goku Charging) -->
<div id="loader" class="fixed inset-0 bg-black flex items-center justify-center z-50 hidden">
    <div class="text-center">
        <p class="text-yellow-400 text-xl animate-pulse">⚡ Charging Energy...</p>
    </div>
</div>

<!-- 🔥 LOGIN CARD -->
<div class="bg-zinc-900 p-8 rounded-2xl shadow-2xl w-80 relative overflow-hidden">

    <!-- Glow Effect -->
    <div class="absolute inset-0 bg-yellow-400 opacity-10 blur-2xl"></div>

    <!-- Title -->
    <h1 class="text-2xl font-bold text-center mb-2">
        ⚡ Welcome Back
    </h1>

    <p class="text-center text-gray-400 mb-6 text-sm">
        Power up and enter marketplace 🚀
    </p>

    <!-- Goku Journey -->
    <div class="flex justify-center gap-4 text-sm mb-4">
        <span class="text-yellow-400 animate-pulse">👶</span>
        <span class="text-orange-400 animate-pulse">🧑</span>
        <span class="text-blue-400 animate-pulse">⚡</span>
    </div>

    <!-- FORM -->
    <form action="/login" method="POST" id="loginForm">

        <input name="email" placeholder="Email"
        class="w-full p-2 mb-3 rounded text-black outline-none">

        <input name="password" type="password" placeholder="Password"
        class="w-full p-2 mb-4 rounded text-black outline-none">

        <button class="bg-blue-500 hover:bg-blue-600 w-full p-2 rounded font-semibold transition">
            Login 🚀
        </button>

    </form>

    <!-- Footer -->
    <p class="text-center text-xs text-gray-500 mt-4">
        New here? <a href="/signUp" class="text-blue-400">Create Account</a>
    </p>

</div>

<!-- ⚡ SCRIPT -->
<script>
const form = document.getElementById("loginForm");
const loader = document.getElementById("loader");

form.addEventListener("submit", () => {
    loader.classList.remove("hidden");
});
</script>

</body>
</html>