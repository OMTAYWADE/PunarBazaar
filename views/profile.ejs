<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>My Profile - PunarBazaar</title>
<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

<style>
@keyframes slideIn {
  from { transform: translateX(120%); opacity: 0; }
  to { transform: translateX(0); opacity: 1; }
}
.animate-slideIn {
  animation: slideIn 0.4s ease;
}
</style>
</head>

<body class="min-h-screen bg-gradient-to-br from-slate-100 via-indigo-50 to-slate-200">

<!-- HEADER -->
<div class="bg-white/90 backdrop-blur border-b shadow-sm">
    <div class="max-w-6xl mx-auto px-4 py-4 flex justify-between items-center">
        <h1 class="text-lg font-semibold text-gray-800">My Profile</h1>
        <a href="/" class="text-sm text-indigo-600 hover:underline">Back</a>
    </div>
</div>

<div class="max-w-6xl mx-auto mt-6 px-4">

<!-- ALERT -->
<% if(!user.phone || !user.college || !user.branch || !user.year){ %>
<div class="bg-yellow-50 border border-yellow-200 text-yellow-700 p-3 rounded-lg mb-5 text-sm">
    Complete your profile to start selling
</div>
<% } %>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6">

<!-- LEFT -->
<div class="bg-white rounded-xl shadow p-5">

<div class="flex items-center gap-3 mb-5">
<div class="w-12 h-12 bg-indigo-100 text-indigo-600 flex items-center justify-center rounded-full font-bold">
<%= user.name.charAt(0) %>
</div>
<div>
<p class="font-semibold"><%= user.name %></p>
<p class="text-xs text-gray-500"><%= user.email %></p>
</div>
</div>

<p class="text-xs text-gray-500 mb-1">Verification</p>

<% if(user.verificationStatus === "verified"){ %>
<span class="bg-green-100 text-green-700 px-2 py-1 rounded text-xs">Verified</span>
<% } else if(user.verificationStatus === "pending"){ %>
<span class="bg-yellow-100 text-yellow-700 px-2 py-1 rounded text-xs">Pending</span>
<% } else { %>
<span class="bg-red-100 text-red-700 px-2 py-1 rounded text-xs">Not Verified</span>
<% } %>

<div class="mt-5">
<p class="text-xs text-gray-500 mb-1">Trust Score</p>

<div class="w-full bg-gray-200 h-2 rounded">
<div class="bg-gradient-to-r from-indigo-600 to-purple-500 h-2 rounded"
style="width:<%= user.trustScore %>%"></div>
</div>

<p class="text-xs mt-1"><%= user.trustScore %>/100</p>
</div>

</div>

<!-- RIGHT -->
<div class="md:col-span-2 bg-white rounded-xl shadow p-6">

<h2 class="font-semibold mb-5">Update Profile</h2>

<form id="profileForm" enctype="multipart/form-data">

<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

<input name="phone" placeholder="Phone" value="<%= user.phone || '' %>" class="p-2 border rounded">
<input name="college" placeholder="College" value="<%= user.college || '' %>" class="p-2 border rounded">
<input name="branch" placeholder="Branch" value="<%= user.branch || '' %>" class="p-2 border rounded">
<input name="year" placeholder="Year" value="<%= user.year || '' %>" class="p-2 border rounded">
<input name="division" placeholder="Division" value="<%= user.division || '' %>" class="p-2 border rounded">

</div>

<div class="mt-5">
<input type="file" name="collegeIdImage">
<% if(user.collegeIdImage){ %>
<img src="<%= user.collegeIdImage %>" class="h-20 mt-3">
<% } %>
</div>

<button class="mt-6 w-full py-2 bg-indigo-600 text-white rounded">
Save
</button>

</form>

</div>

</div>
</div>

<!-- LOADER -->
<div id="loader" class="fixed inset-0 bg-white/70 flex items-center justify-center hidden">
<div class="w-6 h-6 border-2 border-indigo-600 border-t-transparent rounded-full animate-spin"></div>
</div>

<!-- ERROR -->
<div id="errorBox" class="fixed top-5 right-5 hidden">
<div class="bg-red-500 text-white px-4 py-2 rounded animate-slideIn">
<span id="errorText"></span>
</div>
</div>

<!-- SUCCESS -->
<div id="successBox" class="fixed top-5 right-5 hidden">
<div class="bg-green-500 text-white px-4 py-2 rounded animate-slideIn">
<span id="successText"></span>
</div>
</div>

<script>
const form = document.getElementById("profileForm");
const loader = document.getElementById("loader");

form.addEventListener("submit", async (e)=>{
e.preventDefault();

loader.classList.remove("hidden");

const data = new FormData(form);

const res = await fetch("/profile", {
method:"POST",
body:data
});

const result = await res.json();

loader.classList.add("hidden");

if(!res.ok || !result.success){
showError(result.message || "Error");
return;
}

showSuccess("Updated successfully");

setTimeout(()=> location.reload(),1200);
});

function showError(msg){
document.getElementById("errorText").innerText = msg;
document.getElementById("errorBox").classList.remove("hidden");
setTimeout(()=>document.getElementById("errorBox").classList.add("hidden"),3000);
}

function showSuccess(msg){
document.getElementById("successText").innerText = msg;
document.getElementById("successBox").classList.remove("hidden");
setTimeout(()=>document.getElementById("successBox").classList.add("hidden"),3000);
}
</script>

</body>
</html>