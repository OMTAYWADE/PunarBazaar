<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Profile - PunarBazaar</title>

<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

<style>
@keyframes fadeUp {
  from { opacity:0; transform: translateY(20px); }
  to { opacity:1; transform: translateY(0); }
}
.animate-fadeUp {
  animation: fadeUp 0.6s ease forwards;
}

@keyframes slideIn {
  from { transform: translateX(120%); opacity: 0; }
  to { transform: translateX(0); opacity: 1; }
}
.animate-slideIn {
  animation: slideIn 0.4s ease;
}

.glow {
  box-shadow: 0 0 40px rgba(99,102,241,0.15);
}
</style>
</head>

<body class="min-h-screen bg-gradient-to-br from-slate-900 via-indigo-900 to-slate-800 text-white">

<div class="max-w-6xl mx-auto px-4 py-8 animate-fadeUp">

<!-- HEADER -->
<div class="flex flex-col sm:flex-row justify-between items-center mb-8 gap-4">

    <div>
        <h1 class="text-2xl font-bold">👤 My Profile</h1>
        <p class="text-sm text-indigo-200">Manage your identity & trust</p>
    </div>

    <a href="/" class="px-4 py-2 rounded-xl bg-white/10 hover:bg-white/20 transition backdrop-blur">
        ← Back
    </a>

</div>

<!-- ALERT -->
<% if(!user.phone || !user.college || !user.branch || !user.year){ %>
<div class="bg-yellow-400/20 border border-yellow-400/40 text-yellow-200 p-4 rounded-xl mb-6 text-sm backdrop-blur">
⚠️ Complete your profile to unlock full features
</div>
<% } %>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

<!-- LEFT CARD -->
<div class="bg-white/10 backdrop-blur-xl rounded-2xl p-6 border border-white/10 glow">

    <div class="flex items-center gap-4 mb-6">
        <div class="w-16 h-16 bg-gradient-to-r from-indigo-500 to-purple-500 rounded-full flex items-center justify-center text-xl font-bold shadow-lg">
            <%= user.name.charAt(0) %>
        </div>
        <div>
            <p class="font-semibold text-lg"><%= user.name %></p>
            <p class="text-sm text-indigo-200"><%= user.email %></p>
        </div>
    </div>

    <!-- Verification -->
    <div class="mb-6">
        <p class="text-xs text-indigo-300 mb-2">Verification</p>

        <% if(user.verificationStatus === "verified"){ %>
        <span class="bg-green-400/20 text-green-300 px-3 py-1 rounded-full text-xs">✔ Verified</span>
        <% } else if(user.verificationStatus === "pending"){ %>
        <span class="bg-yellow-400/20 text-yellow-300 px-3 py-1 rounded-full text-xs">⏳ Pending</span>
        <% } else { %>
        <span class="bg-red-400/20 text-red-300 px-3 py-1 rounded-full text-xs">✖ Not Verified</span>
        <% } %>
    </div>

    <!-- Trust -->
    <div>
        <p class="text-xs text-indigo-300 mb-2">Trust Score</p>

        <div class="w-full bg-white/10 h-3 rounded-full overflow-hidden">
            <div class="bg-gradient-to-r from-indigo-500 to-purple-500 h-3 rounded-full transition-all duration-700"
            style="width:<%= user.trustScore %>%"></div>
        </div>

        <p class="text-xs mt-2 text-indigo-200"><%= user.trustScore %>/100</p>
    </div>

</div>

<!-- RIGHT FORM -->
<div class="lg:col-span-2 bg-white/10 backdrop-blur-xl rounded-2xl p-6 border border-white/10 glow">

<h2 class="text-lg font-semibold mb-6">Update Profile</h2>

<form id="profileForm" enctype="multipart/form-data" class="space-y-5">

<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

<input name="phone" placeholder="Phone"
value="<%= user.phone || '' %>"
class="p-3 bg-white/10 border border-white/10 rounded-xl focus:ring-2 focus:ring-indigo-400 outline-none">

<input name="college" placeholder="College"
value="<%= user.college || '' %>"
class="p-3 bg-white/10 border border-white/10 rounded-xl focus:ring-2 focus:ring-indigo-400 outline-none">

<input name="branch" placeholder="Branch"
value="<%= user.branch || '' %>"
class="p-3 bg-white/10 border border-white/10 rounded-xl focus:ring-2 focus:ring-indigo-400 outline-none">

<input name="year" placeholder="Year"
value="<%= user.year || '' %>"
class="p-3 bg-white/10 border border-white/10 rounded-xl focus:ring-2 focus:ring-indigo-400 outline-none">

<input name="division" placeholder="Division"
value="<%= user.division || '' %>"
class="p-3 bg-white/10 border border-white/10 rounded-xl focus:ring-2 focus:ring-indigo-400 outline-none">

</div>

<!-- FILE -->
<div>
<p class="text-xs text-indigo-300 mb-2">College ID</p>

<input type="file" name="collegeIdImage">

<% if(user.collegeIdImage){ %>
<img src="<%= user.collegeIdImage %>" class="h-20 mt-3 rounded-lg border border-white/20">
<% } %>
</div>

<button class="w-full py-3 rounded-xl font-medium
bg-gradient-to-r from-indigo-600 to-purple-500
hover:scale-[1.03] active:scale-[0.97]
transition shadow-lg">
Save Changes
</button>

</form>

</div>

</div>

</div>

<!-- LOADER -->
<div id="loader" class="fixed inset-0 bg-black/40 backdrop-blur flex items-center justify-center hidden">
<div class="w-10 h-10 border-4 border-indigo-400 border-t-transparent rounded-full animate-spin"></div>
</div>

<!-- ERROR -->
<div id="errorBox" class="fixed top-5 right-5 hidden z-50">
    <div class="bg-red-500 text-white px-5 py-3 rounded-xl shadow-lg animate-slideIn">
        ❌ <span id="errorText"></span>
    </div>
</div>

<!-- SUCCESS -->
<div id="successBox" class="fixed top-5 right-5 hidden z-50">
    <div class="bg-green-500 text-white px-5 py-3 rounded-xl shadow-lg animate-slideIn">
        ✅ <span id="successText"></span>
    </div>
</div>

<script>
const form = document.getElementById("profileForm");
const loader = document.getElementById("loader");

form.addEventListener("submit", async (e)=>{
    e.preventDefault();

    loader.classList.remove("hidden");

    const data = new FormData(form);

    try {
        const res = await fetch("/profile", {
            method:"POST",
            body:data,
            credentials:"include"
        });

        const result = await res.json();

        loader.classList.add("hidden");

        if(!res.ok || !result.success){
            showError(result.message || "Error");
            return;
        }

        showSuccess("Updated successfully");

        setTimeout(() => {
            location.reload();
        }, 1200);

    } catch(err){
        loader.classList.add("hidden");
        showError("Something went wrong");
    }
});

function showError(msg){
    document.getElementById("errorText").innerText = msg;
    const box = document.getElementById("errorBox");
    box.classList.remove("hidden");
    setTimeout(()=>box.classList.add("hidden"),3000);
}

function showSuccess(msg){
    document.getElementById("successText").innerText = msg;
    const box = document.getElementById("successBox");
    box.classList.remove("hidden");
    setTimeout(()=>box.classList.add("hidden"),3000);
}
</script>

</body>
</html>