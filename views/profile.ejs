<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>My Profile</title>
<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-gray-50 min-h-screen">

<!-- HEADER -->

<div class="bg-white shadow-sm border-b p-4">
    <h1 class="text-xl font-semibold text-gray-700 text-center">
        My Profile
    </h1>
</div>

<!-- MAIN -->

<div class="max-w-4xl mx-auto mt-6 px-4">

```
<!-- WARNING -->
<% if(!user.phone || !user.college || !user.branch || !user.year){ %>
    <div class="bg-red-100 text-red-600 p-3 rounded mb-4 text-center">
        ⚠ Complete your profile to start selling
    </div>
<% } %>

<!-- GRID -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6">

    <!-- LEFT PANEL -->
    <div class="bg-white p-4 rounded-lg shadow-sm border">

        <h2 class="font-semibold mb-3 text-gray-700">
            Basic Info
        </h2>

        <p class="text-sm"><strong>Name:</strong> <%= user.name %></p>
        <p class="text-sm"><strong>Email:</strong> <%= user.email %></p>

        <!-- STATUS -->
        <div class="mt-4">

            <% if(user.verificationStatus === "verified"){ %>
                <span class="bg-green-100 text-green-700 px-2 py-1 rounded text-xs">
                    🎓 Verified
                </span>
            <% } else if(user.verificationStatus === "pending"){ %>
                <span class="bg-yellow-100 text-yellow-700 px-2 py-1 rounded text-xs">
                    Pending
                </span>
            <% } else { %>
                <span class="bg-red-100 text-red-700 px-2 py-1 rounded text-xs">
                    Not Verified
                </span>
            <% } %>

        </div>

    </div>

    <!-- RIGHT PANEL -->
    <div class="md:col-span-2 bg-white p-5 rounded-lg shadow-sm border">

        <h2 class="font-semibold mb-4 text-gray-700">
            Update Profile
        </h2>

        <form action="/profile" method="POST" enctype="multipart/form-data" id="profileForm">

            <!-- GRID FORM -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">

                <input name="phone" value="<%= user.phone || '' %>" 
                placeholder="Phone"
                class="p-2 border rounded outline-none focus:ring-2 focus:ring-blue-400">

                <input name="college" value="<%= user.college || '' %>" 
                placeholder="College"
                class="p-2 border rounded outline-none focus:ring-2 focus:ring-blue-400">

                <input name="branch" value="<%= user.branch || '' %>" 
                placeholder="Branch"
                class="p-2 border rounded outline-none focus:ring-2 focus:ring-blue-400">

                <input name="year" value="<%= user.year || '' %>" 
                placeholder="Year"
                class="p-2 border rounded outline-none focus:ring-2 focus:ring-blue-400">

                <input name="division" value="<%= user.division || '' %>" 
                placeholder="Division"
                class="p-2 border rounded outline-none focus:ring-2 focus:ring-blue-400">

            </div>

            <!-- FILE -->
            <label class="block mt-4 text-sm text-gray-600">
                Upload College ID
            </label>

            <input type="file" name="collegeIdImage"
            class="mb-3 w-full text-sm">

            <!-- PREVIEW -->
            <% if(user.collegeIdImage){ %>
                <img src="<%= user.collegeIdImage %>" 
                class="h-24 rounded border mb-3">
            <% } %>

            <!-- BUTTON -->
            <button class="bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded w-full transition">
                Save Changes
            </button>

        </form>

    </div>

</div>
```

</div>

<!-- LOADER -->

<div id="loader" class="fixed inset-0 bg-white flex items-center justify-center z-50 hidden">
    <p class="text-blue-500 animate-pulse">Saving...</p>
</div>

<script>
const form = document.getElementById("profileForm");
const loader = document.getElementById("loader");

form.addEventListener("submit", () => {
    loader.classList.remove("hidden");
});
</script>

</body>
</html>
