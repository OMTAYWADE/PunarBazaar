<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>My Profile - PunarBazaar</title>

<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

<style>
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}
.animate-fadeUp {
  animation: fadeUp 0.6s ease forwards;
}

@keyframes slideIn {
  from { transform: translateX(120%); opacity: 0; }
  to { transform: translateX(0); opacity: 1; }
}
.animate-slideIn {
  animation: slideIn 0.4s ease;
}
</style>
</head>

<body class="min-h-screen bg-gradient-to-br from-slate-100 via-indigo-50 to-slate-200">

<div class="max-w-6xl mx-auto px-4 py-8 animate-fadeUp">

<!-- NAVBAR -->
<div class="bg-white/60 backdrop-blur-xl border border-white/40 
rounded-2xl shadow-md px-6 py-4 flex justify-between items-center mb-6">

    <h1 class="text-xl font-bold text-indigo-700 tracking-wide">
        PunarBazaar
    </h1>

    <a href="/" class="text-sm px-4 py-1.5 rounded-lg bg-indigo-100 text-indigo-700 hover:bg-indigo-200 transition">
        ← Back
    </a>

</div>

<!-- ALERT -->
<% if(!user.phone || !user.college || !user.branch || !user.year){ %>
<div class="bg-yellow-50 border border-yellow-200 text-yellow-800 p-4 rounded-xl mb-6 shadow-sm text-sm">
    ⚠️ Complete your profile to start selling
</div>
<% } %>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6">

<!-- LEFT CARD -->
<div class="bg-white/70 backdrop-blur-xl rounded-2xl shadow-lg p-6 border border-white/40">

    <div class="flex items-center gap-4 mb-6">
        <div class="w-14 h-14 bg-gradient-to-r from-indigo-500 to-purple-500 text-white flex items-center justify-center rounded-full text-lg font-bold shadow">
            <%= user.name.charAt(0) %>
        </div>
        <div>
            <p class="font-semibold text-gray-800 text-lg"><%= user.name %></p>
            <p class="text-xs text-gray-500"><%= user.email %></p>
        </div>
    </div>

    <!-- VERIFICATION -->
    <div class="mb-5">
        <p class="text-xs text-gray-500 mb-1">Verification</p>

        <% if(user.verificationStatus === "verified"){ %>
        <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-xs font-medium">✔ Verified</span>
        <% } else if(user.verificationStatus === "pending"){ %>
        <span class="bg-yellow-100 text-yellow-700 px-3 py-1 rounded-full text-xs font-medium">⏳ Pending</span>
        <% } else { %>
        <span class="bg-red-100 text-red-700 px-3 py-1 rounded-full text-xs font-medium">✖ Not Verified</span>
        <% } %>
    </div>

    <!-- TRUST SCORE -->
    <div>
        <p class="text-xs text-gray-500 mb-2">Trust Score</p>

        <div class="w-full bg-gray-200 h-2 rounded-full overflow-hidden">
            <div class="bg-gradient-to-r from-indigo-500 to-purple-500 h-2 rounded-full transition-all duration-700"
            style="width:<%= user.trustScore %>%"></div>
        </div>

        <p class="text-xs mt-2 text-gray-600 font-medium">
            <%= user.trustScore %>/100
        </p>
    </div>

</div>

<!-- RIGHT FORM -->
<div class="md:col-span-2 bg-white/70 backdrop-blur-xl rounded-2xl shadow-lg p-6 border border-white/40">

    <h2 class="font-semibold text-lg text-gray-800 mb-6">Update Profile</h2>

    <form id="profileForm" enctype="multipart/form-data" class="space-y-5">

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

            <input name="phone" placeholder="Phone"
            value="<%= user.phone || '' %>"
            class="p-3 border rounded-xl focus:ring-2 focus:ring-indigo-400 outline-none transition">

            <input name="college" placeholder="College"
            value="<%= user.college || '' %>"
            class="p-3 border rounded-xl focus:ring-2 focus:ring-indigo-400 outline-none transition">

            <input name="branch" placeholder="Branch"
            value="<%= user.branch || '' %>"
            class="p-3 border rounded-xl focus:ring-2 focus:ring-indigo-400 outline-none transition">

            <input name="year" placeholder="Year"
            value="<%= user.year || '' %>"
            class="p-3 border rounded-xl focus:ring-2 focus:ring-indigo-400 outline-none transition">

            <input name="division" placeholder="Division"
            value="<%= user.division || '' %>"
            class="p-3 border rounded-xl focus:ring-2 focus:ring-indigo-400 outline-none transition">

        </div>

        <!-- FILE -->
        <div>
            <p class="text-xs text-gray-500 mb-2">College ID</p>

            <input type="file" name="collegeIdImage" class="text-sm">

            <% if(user.collegeIdImage){ %>
            <img src="<%= user.collegeIdImage %>" 
            class="h-20 mt-3 rounded-lg border shadow-sm">
            <% } %>
        </div>

        <!-- BUTTON -->
        <button class="w-full py-3 rounded-xl text-white font-medium
        bg-gradient-to-r from-indigo-600 to-purple-500
        hover:scale-[1.02] active:scale-[0.97]
        transition shadow-md">
            Save Changes
        </button>

    </form>

</div>

</div>
</div>

<!-- LOADER -->
<div id="loader" class="fixed inset-0 bg-white/70 backdrop-blur flex items-center justify-center hidden">
    <div class="w-8 h-8 border-2 border-indigo-600 border-t-transparent rounded-full animate-spin"></div>
</div>

<!-- ERROR -->
<div id="errorBox" class="fixed top-5 right-5 hidden z-50">
    <div class="bg-red-500 text-white px-5 py-3 rounded-xl shadow-lg animate-slideIn">
        ❌ <span id="errorText"></span>
    </div>
</div>

<!-- SUCCESS -->
<div id="successBox" class="fixed top-5 right-5 hidden z-50">
    <div class="bg-green-500 text-white px-5 py-3 rounded-xl shadow-lg animate-slideIn">
        ✅ <span id="successText"></span>
    </div>
</div>

<script>
const form = document.getElementById("profileForm");
const loader = document.getElementById("loader");

form.addEventListener("submit", async (e)=>{
    e.preventDefault();

    loader.classList.remove("hidden");

    const data = new FormData(form);

    try {
        const res = await fetch("/profile", {
            method:"POST",
            body:data
        });

        const result = await res.json();

        loader.classList.add("hidden");

        if(!res.ok || !result.success){
            showError(result.message || "Error");
            return;
        }

        showSuccess("Updated successfully");

        setTimeout(() => {
            window.location.href = "/";
        }, 1200);

    } catch(err){
        loader.classList.add("hidden");
        showError("Something went wrong");
    }
});

function showError(msg){
    document.getElementById("errorText").innerText = msg;
    const box = document.getElementById("errorBox");
    box.classList.remove("hidden");
    setTimeout(()=>box.classList.add("hidden"),3000);
}

function showSuccess(msg){
    document.getElementById("successText").innerText = msg;
    const box = document.getElementById("successBox");
    box.classList.remove("hidden");
    setTimeout(()=>box.classList.add("hidden"),3000);
}
</script>

</body>
</html>