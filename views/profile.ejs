<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>My Profile - PunarBazaar</title>
<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="min-h-screen bg-gradient-to-br from-slate-100 via-indigo-50 to-slate-200">

<!-- HEADER -->

<div class="bg-white/90 backdrop-blur border-b shadow-sm">
    <div class="max-w-6xl mx-auto px-4 py-4 flex justify-between items-center">
        <h1 class="text-lg font-semibold text-gray-800">My Profile</h1>
        <a href="/" class="text-sm text-indigo-600 hover:underline">Back to Home</a>
    </div>
</div>

<!-- MAIN -->

<div class="max-w-6xl mx-auto mt-6 px-4">

```
<!-- ALERT -->
<% if(!user.phone || !user.college || !user.branch || !user.year){ %>
    <div class="bg-yellow-50 border border-yellow-200 text-yellow-700 p-3 rounded-lg mb-5 text-sm flex justify-between items-center">
        <span>Complete your profile to start selling</span>
        <span class="font-medium">Required</span>
    </div>
<% } %>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6">

    <!-- LEFT PANEL -->
    <div class="bg-white/90 backdrop-blur border rounded-xl shadow-md p-5">

        <!-- USER -->
        <div class="flex items-center gap-3 mb-5">
            <div class="w-12 h-12 bg-indigo-100 text-indigo-600 flex items-center justify-center rounded-full text-lg font-bold">
                <%= user.name.charAt(0) %>
            </div>
            <div>
                <p class="font-semibold text-gray-800"><%= user.name %></p>
                <p class="text-xs text-gray-500"><%= user.email %></p>
            </div>
        </div>

        <!-- STATUS -->
        <div class="mb-5">
            <p class="text-xs text-gray-500 mb-1">Verification Status</p>

            <% if(user.verificationStatus === "verified"){ %>
                <span class="bg-green-100 text-green-700 px-2 py-1 rounded text-xs font-medium">
                    Verified Student
                </span>
            <% } else if(user.verificationStatus === "pending"){ %>
                <span class="bg-yellow-100 text-yellow-700 px-2 py-1 rounded text-xs">
                    Pending Review
                </span>
            <% } else { %>
                <span class="bg-red-100 text-red-700 px-2 py-1 rounded text-xs">
                    Not Verified
                </span>
            <% } %>
        </div>

        <!-- TRUST SCORE -->
        <div>
            <p class="text-xs text-gray-500 mb-2">Trust Score</p>

            <div class="w-full bg-gray-200 h-2 rounded">
                <div class="bg-indigo-600 h-2 rounded transition-all"
                    style="width: <%= user.trustScore %>%;"></div>
            </div>

            <p class="text-xs text-gray-600 mt-1">
                <%= user.trustScore %> / 100
            </p>
        </div>

    </div>

    <!-- RIGHT PANEL -->
    <div class="md:col-span-2 bg-white/90 backdrop-blur border rounded-xl shadow-md p-6">

        <h2 class="text-md font-semibold text-gray-800 mb-5">
            Update Profile
        </h2>

        <form action="/profile" method="POST" enctype="multipart/form-data" id="profileForm">

            <!-- GRID -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

                <div>
                    <label class="text-xs text-gray-500">Phone</label>
                    <input name="phone" value="<%= user.phone || '' %>"
                    class="w-full p-2.5 border border-gray-300 rounded-lg 
                    focus:ring-2 focus:ring-indigo-500 outline-none transition hover:border-indigo-400">
                </div>

                <div>
                    <label class="text-xs text-gray-500">College</label>
                    <input name="college" value="<%= user.college || '' %>"
                    class="w-full p-2.5 border border-gray-300 rounded-lg 
                    focus:ring-2 focus:ring-indigo-500 outline-none transition hover:border-indigo-400">
                </div>

                <div>
                    <label class="text-xs text-gray-500">Branch</label>
                    <input name="branch" value="<%= user.branch || '' %>"
                    class="w-full p-2.5 border border-gray-300 rounded-lg 
                    focus:ring-2 focus:ring-indigo-500 outline-none transition hover:border-indigo-400">
                </div>

                <div>
                    <label class="text-xs text-gray-500">Year</label>
                    <input name="year" value="<%= user.year || '' %>"
                    class="w-full p-2.5 border border-gray-300 rounded-lg 
                    focus:ring-2 focus:ring-indigo-500 outline-none transition hover:border-indigo-400">
                </div>

                <div>
                    <label class="text-xs text-gray-500">Division</label>
                    <input name="division" value="<%= user.division || '' %>"
                    class="w-full p-2.5 border border-gray-300 rounded-lg 
                    focus:ring-2 focus:ring-indigo-500 outline-none transition hover:border-indigo-400">
                </div>

            </div>

            <!-- FILE -->
            <div class="mt-6">
                <label class="text-xs text-gray-500 block mb-1">
                    Upload College ID
                </label>

                <input type="file" name="collegeIdImage"
                class="w-full text-sm">

                <% if(user.collegeIdImage){ %>
                    <img src="<%= user.collegeIdImage %>"
                    class="h-20 mt-3 rounded border shadow-sm">
                <% } %>
            </div>

            <!-- BUTTON -->
            <button 
            class="mt-6 bg-gradient-to-r from-indigo-600 to-indigo-500 text-white w-full py-2.5 rounded-lg 
            font-medium shadow hover:scale-[1.02] hover:shadow-md transition">
                Save Changes
            </button>

        </form>

    </div>

</div>
```

</div>

<!-- LOADER -->

<div id="loader" class="fixed inset-0 bg-white/80 backdrop-blur flex items-center justify-center hidden">
    <div class="text-center">
        <div class="w-6 h-6 border-2 border-indigo-600 border-t-transparent rounded-full animate-spin mx-auto mb-2"></div>
        <p class="text-indigo-600 text-sm">Saving...</p>
    </div>
</div>

<script>
document.getElementById("profileForm").addEventListener("submit", () => {
    document.getElementById("loader").classList.remove("hidden");
});
</script>

</body>
</html>
