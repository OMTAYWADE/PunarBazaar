<!DOCTYPE html>
<html>
<head>
<title>My Profile</title>
<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-black text-white min-h-screen flex items-center justify-center">

<!-- ⚡ LOADER -->
<div id="loader" class="fixed inset-0 bg-black flex items-center justify-center z-50 hidden">
    <p class="text-yellow-400 text-xl animate-pulse">⚡ Saving Power...</p>
</div>

<!-- 🌟 PROFILE CARD -->
<div class="max-w-xl w-full bg-zinc-900 p-6 rounded-2xl shadow-2xl relative overflow-hidden">

    <!-- Glow Effect -->
    <div class="absolute inset-0 bg-blue-500 opacity-10 blur-3xl"></div>

    <!-- Header -->
    <h1 class="text-2xl font-bold mb-2 text-center">
        ⚡ My Power Profile
    </h1>

    <p class="text-center text-gray-400 text-sm mb-4">
        Build trust. Increase your power level 🚀
    </p>

    <!-- Goku Journey -->
    <div class="flex justify-center gap-4 text-lg mb-4">
        <span class="text-yellow-400 animate-pulse">👶</span>
        <span class="text-orange-400 animate-pulse">🧑</span>
        <span class="text-blue-400 animate-pulse">⚡</span>
    </div>

    <!-- ⚠ WARNING -->
    <% if(!user.phone || !user.college || !user.branch || !user.year){ %>
        <p class="text-red-400 text-center mb-4">
            ⚠ Complete your profile to start selling items
        </p>
    <% } %>

    <!-- USER INFO -->
    <div class="bg-zinc-800 p-4 rounded mb-4">
        <p><strong>Name:</strong> <%= user.name %></p>
        <p><strong>Email:</strong> <%= user.email %></p>
    </div>

    <!-- VERIFICATION STATUS -->
    <div class="text-center mb-4">

        <% if(user.verificationStatus === "verified"){ %>
            <p class="text-green-400 font-semibold">🎓 Verified Student</p>
        <% } else if(user.verificationStatus === "pending"){ %>
            <p class="text-yellow-400">⏳ Verification Pending</p>
        <% } else { %>
            <p class="text-red-400">❌ Not Verified</p>
        <% } %>

    </div>

    <!-- FORM -->
    <form action="/profile" method="POST" enctype="multipart/form-data" id="profileForm">

        <input name="phone" value="<%= user.phone || '' %>" 
        placeholder="📱 Phone Number"
        class="w-full p-2 mb-2 rounded text-black">

        <input name="college" value="<%= user.college || '' %>" 
        placeholder="🏫 College Name"
        class="w-full p-2 mb-2 rounded text-black">

        <input name="branch" value="<%= user.branch || '' %>" 
        placeholder="📚 Branch"
        class="w-full p-2 mb-2 rounded text-black">

        <input name="year" value="<%= user.year || '' %>" 
        placeholder="🎓 Year"
        class="w-full p-2 mb-2 rounded text-black">

        <input name="division" value="<%= user.division || '' %>" 
        placeholder="🏷 Division"
        class="w-full p-2 mb-3 rounded text-black">

        <!-- Upload -->
        <label class="block mb-1 text-sm">Upload College ID</label>
        <input type="file" name="collegeIdImage" class="mb-3">

        <!-- Preview -->
        <% if(user.collegeIdImage){ %>
            <img src="<%= user.collegeIdImage %>" class="h-32 mb-3 rounded border">
        <% } %>

        <!-- Submit -->
        <button class="bg-blue-500 hover:bg-blue-600 w-full p-2 rounded font-semibold transition">
            Save Profile 🚀
        </button>

    </form>

</div>

<!-- ⚡ SCRIPT -->
<script>
const form = document.getElementById("profileForm");
const loader = document.getElementById("loader");

form.addEventListener("submit", () => {
    loader.classList.remove("hidden");
});
</script>

</body>
</html>