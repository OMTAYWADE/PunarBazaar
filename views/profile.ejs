<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>My Profile</title>
<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-gray-50 min-h-screen">

<!-- HEADER -->

<div class="bg-white border-b">
    <div class="max-w-6xl mx-auto px-4 py-4 flex justify-between items-center">
        <h1 class="text-lg font-semibold text-gray-800">My Profile</h1>
        <a href="/" class="text-sm text-indigo-600">Back to Home</a>
    </div>
</div>

<!-- MAIN -->

<div class="max-w-6xl mx-auto mt-6 px-4">

```
<!-- ALERT -->
<% if(!user.phone || !user.college || !user.branch || !user.year){ %>
    <div class="bg-yellow-50 border border-yellow-200 text-yellow-700 p-3 rounded mb-5 text-sm flex justify-between items-center">
        <span>Complete your profile to start selling</span>
        <span class="font-medium">Required</span>
    </div>
<% } %>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6">

    <!-- LEFT: USER CARD -->
    <div class="bg-white rounded-lg border shadow-sm p-5">

        <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-indigo-100 text-indigo-600 flex items-center justify-center rounded-full font-semibold">
                <%= user.name.charAt(0) %>
            </div>
            <div>
                <p class="font-medium text-gray-800"><%= user.name %></p>
                <p class="text-xs text-gray-500"><%= user.email %></p>
            </div>
        </div>

        <!-- STATUS -->
        <div class="mb-4">
            <p class="text-xs text-gray-500 mb-1">Verification Status</p>

            <% if(user.verificationStatus === "verified"){ %>
                <span class="bg-green-100 text-green-700 px-2 py-1 rounded text-xs font-medium">
                    Verified Student
                </span>
            <% } else if(user.verificationStatus === "pending"){ %>
                <span class="bg-yellow-100 text-yellow-700 px-2 py-1 rounded text-xs">
                    Pending Review
                </span>
            <% } else { %>
                <span class="bg-red-100 text-red-700 px-2 py-1 rounded text-xs">
                    Not Verified
                </span>
            <% } %>
        </div>

        <!-- TRUST SCORE -->
        <div>
            <p class="text-xs text-gray-500 mb-1">Trust Score</p>
            <div class="w-full bg-gray-200 h-2 rounded">
                <div class="bg-indigo-600 h-2 rounded"
                    style="width: <%= user.trustScore %>%;">
                </div>
            </div>
            <p class="text-xs text-gray-600 mt-1">
                <%= user.trustScore %> / 100
            </p>
        </div>

    </div>

    <!-- RIGHT: FORM -->
    <div class="md:col-span-2 bg-white rounded-lg border shadow-sm p-6">

        <h2 class="text-md font-semibold text-gray-800 mb-4">
            Update Profile
        </h2>

        <form action="/profile" method="POST" enctype="multipart/form-data" id="profileForm">

            <!-- GRID -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

                <div>
                    <label class="text-xs text-gray-500">Phone</label>
                    <input name="phone" value="<%= user.phone || '' %>"
                    class="w-full p-2 border rounded focus:ring-2 focus:ring-indigo-400 outline-none">
                </div>

                <div>
                    <label class="text-xs text-gray-500">College</label>
                    <input name="college" value="<%= user.college || '' %>"
                    class="w-full p-2 border rounded focus:ring-2 focus:ring-indigo-400 outline-none">
                </div>

                <div>
                    <label class="text-xs text-gray-500">Branch</label>
                    <input name="branch" value="<%= user.branch || '' %>"
                    class="w-full p-2 border rounded focus:ring-2 focus:ring-indigo-400 outline-none">
                </div>

                <div>
                    <label class="text-xs text-gray-500">Year</label>
                    <input name="year" value="<%= user.year || '' %>"
                    class="w-full p-2 border rounded focus:ring-2 focus:ring-indigo-400 outline-none">
                </div>

                <div>
                    <label class="text-xs text-gray-500">Division</label>
                    <input name="division" value="<%= user.division || '' %>"
                    class="w-full p-2 border rounded focus:ring-2 focus:ring-indigo-400 outline-none">
                </div>

            </div>

            <!-- FILE -->
            <div class="mt-5">
                <label class="text-xs text-gray-500 block mb-1">
                    Upload College ID
                </label>

                <input type="file" name="collegeIdImage"
                class="w-full text-sm">

                <% if(user.collegeIdImage){ %>
                    <img src="<%= user.collegeIdImage %>"
                    class="h-20 mt-2 rounded border">
                <% } %>
            </div>

            <!-- BUTTON -->
            <button class="mt-6 bg-indigo-600 text-white w-full py-2 rounded hover:bg-indigo-700 transition">
                Save Changes
            </button>

        </form>

    </div>

</div>
```

</div>

<!-- LOADER -->

<div id="loader" class="fixed inset-0 bg-white hidden flex items-center justify-center">
    <p class="text-indigo-600">Saving...</p>
</div>

<script>
document.getElementById("profileForm").addEventListener("submit", () => {
    document.getElementById("loader").classList.remove("hidden");
});
</script>

</body>
</html>
