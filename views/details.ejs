<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= item.name %></title>

<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

<style>
.fade {
  animation: fadeUp 0.45s ease;
}

@keyframes fadeUp {
  from { opacity:0; transform: translateY(12px); }
  to { opacity:1; transform: translateY(0); }
}
</style>

</head>

<body class="bg-gradient-to-br from-slate-100 via-indigo-50 to-slate-200 min-h-screen">

<div class="max-w-4xl mx-auto px-3 sm:px-4 md:px-6 py-4 sm:py-6 fade">

<!-- NAV -->
<div class="flex justify-between items-center mb-5">
  <h1 class="font-bold text-indigo-600 text-lg">PunarBazaar</h1>
  <a href="/" class="text-sm text-gray-500 hover:text-indigo-600 transition">
    ← Back
  </a>
</div>

<!-- IMAGE -->
<div class="rounded-2xl overflow-hidden shadow-md bg-white/90 backdrop-blur hover:shadow-lg transition">
  <% if(item.image){ %>
    <img src="<%= item.image %>" class="w-full h-60 sm:h-72 md:h-80 object-cover transition duration-300 hover:scale-[1.02]">
  <% } else { %>
    <div class="h-60 flex items-center justify-center text-gray-400">
      No Image
    </div>
  <% } %>
</div>

<!-- DETAILS -->
<div class="mt-5 space-y-4">

<div>
  <h1 class="text-lg sm:text-xl font-semibold text-gray-800">
    <%= item.name %>
  </h1>

  <p class="text-indigo-600 text-lg sm:text-xl font-bold mt-1">
    ₹ <%= item.price %>
  </p>

  <p class="text-gray-600 text-sm leading-relaxed mt-2">
    <%= item.desc %>
  </p>
</div>

<% if(isOwner){ %>
<div class="flex gap-2 mt-3">

<button onclick="deleteItem()"
class="flex-1 py-2 rounded-lg bg-red-500 text-white text-sm
hover:bg-red-600 active:scale-[0.97] transition">
🗑 Delete
</button>

</div>
<% } %>

<!-- SELLER -->
<div class="bg-white/90 backdrop-blur rounded-xl p-4 shadow-md hover:shadow-lg transition flex justify-between items-center">
  <div>
    <p class="text-sm font-medium text-gray-800">Verified Seller</p>
    <p class="text-xs text-gray-500">College Verified ✔</p>
  </div>

  <div class="text-right">
    <p class="text-xs text-gray-500">Trust</p>
    <p class="text-indigo-600 font-semibold">
      <%= item.user?.trustScore || 0 %>
    </p>
  </div>
</div>

<!-- CONTACT -->
<div class="grid grid-cols-1 sm:grid-cols-2 gap-3">

<a href="https://wa.me/<%= item.user.phone %>?text=<%= encodeURIComponent(`Hi, I saw your ${item.name}`) %>"
class="py-2.5 sm:py-3 text-center rounded-xl bg-green-500 text-white font-medium 
hover:bg-green-600 hover:scale-[1.02] active:scale-[0.97] transition">
💬 Chat
</a>

<button onclick="copyNumber('<%= item.user.phone %>')"
class="py-2.5 sm:py-3 bg-indigo-600 text-white rounded-xl 
hover:bg-indigo-700 hover:scale-[1.02] active:scale-[0.97] transition">
📋 Copy
</button>

</div>

<!-- DEAL BOX -->
<div class="bg-white/90 backdrop-blur rounded-xl p-4 shadow-md hover:shadow-lg transition space-y-4">
    <% if(unlock && unlock.status === "confirmed" && !isOwner && !unlock.buyerRated){ %>

<div class="bg-white/90 backdrop-blur rounded-xl p-4 shadow-md mt-4 space-y-3">

  <p class="text-sm font-medium text-gray-700">
    Rate Seller ⭐
  </p>

  <div class="flex gap-2">
    <% for(let i=1;i<=5;i++){ %>
      <button onclick="rateSeller(<%= i %>)"
      class="text-xl hover:scale-110 active:scale-95 transition">
        ⭐
      </button>
    <% } %>
  </div>

</div>

<% } %>

<div>
  <p class="text-sm font-medium text-gray-700">Deal Status</p>
  <p id="statusText" class="text-xs text-gray-500 mt-1">
    <%= unlock?.status || "not_started" %>
  </p>
</div>

<!-- UPI -->
<div id="upiBox" class="hidden bg-indigo-50 p-3 rounded-lg text-sm transition">
  <p class="text-gray-600">UPI ID</p>
  <div class="flex justify-between mt-1">
    <span class="font-medium"><%= item.upiId %></span>
    <button onclick="copyUPI('<%= item.upiId %>')" class="text-indigo-600 text-xs">
      Copy
    </button>
  </div>
  <p class="text-xs mt-2 text-gray-500">Amount: ₹ <%= item.price %></p>
</div>

<!-- BUTTON -->
<button id="dealBtn"
class="w-full py-2.5 sm:py-3 rounded-xl text-white font-medium shadow-md 
transition hover:scale-[1.02] active:scale-[0.97]">
Loading...
</button>

</div>

</div>

</div>

<script>
const state = "<%= unlock?.status || 'not_started' %>";
const isOwner = <%= isOwner ? "true" : "false" %>;
const itemId = "<%= item._id %>";

const btn = document.getElementById("dealBtn");
const upiBox = document.getElementById("upiBox");
const statusText = document.getElementById("statusText");

function setButton(text, color, disabled=false){
  btn.innerText = text;
  btn.disabled = disabled;
  btn.className = `w-full py-2.5 sm:py-3 rounded-xl text-white font-medium shadow-md ${color} transition hover:scale-[1.02] active:scale-[0.97]`;
}

function initUI(){
  statusText.innerText = state.replace("_"," ");

  if(state === "not_started" && !isOwner){
    setButton("Start Deal","bg-indigo-600 hover:bg-indigo-700");
  }
  else if(state === "pending" && !isOwner){
    setButton("I Paid","bg-green-600 hover:bg-green-700");
    upiBox.classList.remove("hidden");
  }
  else if(state === "paid" && !isOwner){
    setButton("Waiting for Seller","bg-yellow-500",true);
  }
  else if(state === "paid" && isOwner){
    setButton("Confirm Payment","bg-indigo-600 hover:bg-indigo-700");
  }
  else if(state === "confirmed"){
    setButton("Deal Completed","bg-green-600",true);
  }
  else{
    setButton("Not Available","bg-gray-400",true);
  }
}

async function handleAction(){
  btn.disabled = true;
  btn.innerText = "Processing...";
  btn.classList.add("opacity-70");

  try{
    let url = "";

    if(state === "not_started") url = `/createDeal/${itemId}`;
    else if(state === "pending" && !isOwner) url = `/markPaid/${itemId}`;
    else if(state === "paid" && isOwner) url = `/confirmPayment/${itemId}`;

    if(!url){
      btn.disabled = false;
      btn.classList.remove("opacity-70");
      return;
    }

    const res = await fetch(url,{
      method:"POST",
      credentials:"include"
    });

    const data = await res.json();

    if(data.success){
      location.reload();
    }else{
      alert(data.message || "Try again");
      btn.disabled = false;
      btn.classList.remove("opacity-70");
      initUI();
    }

  }catch(err){
    console.error(err);
    btn.disabled = false;
    btn.classList.remove("opacity-70");
    initUI();
  }
}

function copyUPI(id){
  navigator.clipboard.writeText(id);
  alert("UPI Copied");
}

function copyNumber(num){
  navigator.clipboard.writeText(num);
  alert("Number Copied");
}

async function deleteItem(){
  const confirmDelete = confirm("Delete this item?");
  if(!confirmDelete) return;

  try{
    const res = await fetch(`/item/${itemId}`,{
      method: "DELETE",
      credentials: "include"
    });

    const data = await res.json();

    if(data.success){
      alert("Item deleted");
      window.location.href = "/";
    }else{
      alert(data.message || "Delete failed");
    }

  }catch(err){
    console.error(err);
    alert("Something went wrong");
  }
}

async function rateSeller(stars){
  try{
    const res = await fetch(`/rate/${itemId}`,{
      method:"POST",
      headers: {
        "Content-Type":"application/json"
      },
      body: JSON.stringify({ rating: stars }),
      credentials:"include"
    });

    const data = await res.json();

    if(data.success){
      alert("Thanks for rating!");
      location.reload();
    }else{
      alert(data.message || "Failed");
    }

  }catch(err){
    console.error(err);
  }
}

btn.onclick = handleAction;
initUI();
</script>

</body>
</html>