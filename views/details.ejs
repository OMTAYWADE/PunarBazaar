<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= item.name %>
    </title>

    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

</head>

<body class="bg-gradient-to-br from-slate-100 via-indigo-50 to-slate-200 min-h-screen">

    <div class="max-w-6xl mx-auto px-4 py-8">

        <!-- NAV -->
        <div class="flex justify-between items-center mb-8">
            <h1 class="text-xl font-bold text-indigo-600">PunarBazaar</h1>
            <a href="/" class="text-sm text-gray-600 hover:text-indigo-600">← Back</a>
        </div>

        <!-- GRID -->
        <div class="grid md:grid-cols-2 gap-10">

            <!-- IMAGE -->
            <div class="bg-white rounded-2xl shadow p-4">
                <% if(item.image){ %>
                    <img src="<%= item.image %>" class="w-full h-[320px] object-cover">
                    <% } else { %>
                        <div class="h-96 flex items-center justify-center text-gray-400">
                            No Image
                        </div>
                        <% } %>
            </div>

            <!-- DETAILS -->
            <div class="bg-white/80 backdrop-blur-xl p-5 rounded-2xl shadow-sm space-y-4">

                <div>
                    <h1 class="text-2xl font-semibold text-gray-800">
                        <%= item.name %>
                    </h1>
                    <p class="text-green-600 text-xl font-bold">₹ <%= item.price %>
                    </p>
                </div>

                <p class="text-gray-500 text-sm">
                    <%= item.desc %>
                </p>
                <hr class="border-gray-200">

                <!-- CONTACT (FREE) -->
                <div class="bg-green-50 border border-green-200 rounded-xl p-4 space-y-3">

                    <div class="flex justify-between items-center">
                        <div>
                            <p class="text-xs text-gray-500">Seller</p>
                            <p class="font-semibold text-gray-800">Verified Student</p>
                            <p class="text-xs text-gray-500">College Verified ✔</p>
                        </div>

                        <span class="text-green-600 text-xs font-medium">
                            Trusted
                        </span>
                    </div>

                    <!-- CONTACT -->
                    <div class="bg-white rounded-lg border p-3">
                        <p class="text-xs text-gray-500">Contact</p>
                        <p class="text-base font-semibold text-gray-800">
                            📞 <%= item.user.phone %>
                        </p>
                    </div>

                </div>


                <!-- BUY BUTTON -->
               <div class="space-y-3">

<% if(isUnlocked){ %>

<button class="w-full py-3 bg-green-600 text-white rounded-xl font-semibold cursor-not-allowed">
    ✅ Purchased
</button>

<p class="text-green-600 text-sm text-center">
    You already own this item
</p>

<% } else if(isOwner){ %>

<!-- SELLER VIEW -->
<button onclick="confirmPayment()" id="confirmBtn"
class="w-full py-3 rounded-xl text-white bg-indigo-600 hover:bg-indigo-700 transition">
    ✅ Confirm Payment
</button>

<p class="text-xs text-gray-400 text-center">
    Confirm after receiving payment
</p>

<% } else { %>

<!-- BUYER VIEW -->
<button onclick="payUPI()" id="upiBtn"
class="w-full py-3 rounded-xl text-white bg-green-600 hover:bg-green-700 transition">
    💸 Pay via UPI
</button>

<button onclick="markPaid()" id="markBtn"
class="w-full py-2 rounded-xl border border-indigo-500 text-indigo-600 hover:bg-indigo-50 transition">
    ✅ I Have Paid
</button>

<% if(isPending){ %>
<p class="text-yellow-500 text-sm text-center">
    ⏳ Waiting for seller confirmation
</p>
<% } %>

<p class="text-xs text-gray-400 text-center">
    After payment, click "I Have Paid"
</p>

<% } %>

</div>
                        <p class="text-xs text-gray-400 mt-2 text-center">
                            After payment, contact seller on WhatsApp
                        </p>
                        <p class="text-xs text-gray-400 text-center">
                            🔒 Safe deal • Meet in campus • Verify before paying
                        </p>

                        <% } %>

                            <% if(isOwner){ %>
                                <button id="deleteBtn" class="w-full py-2 rounded-xl text-red-500 font-medium
bg-red-50 hover:bg-red-100 transition">
                                    🗑 Delete Item
                                </button>

                                <button onclick="confirmPayment()">
Confirm Payment ✅
</button>
                                <% } %>

                                    <!-- WHATSAPP -->
                                    <div class="flex gap-2">

                                        <!-- WhatsApp -->
                                        <a href="https://wa.me/<%= item.user.phone %>?text=Hi, I am interested in your item"
                                            target="_blank"
                                            class="flex-1 text-center py-2.5 rounded-xl bg-green-500 text-white font-medium hover:bg-green-600 transition">
                                            💬 WhatsApp
                                        </a>

                                        <!-- Copy -->
                                        <button onclick="copyNumber('<%= item.user.phone %>')"
                                            class="flex-1 py-2.5 rounded-xl bg-gray-100 text-gray-700 hover:bg-gray-200 transition">
                                            📋 Copy
                                        </button>

                                    </div>

            </div>
        </div>

    </div>

    <!-- SCRIPT -->
    <script>

// 🔥 PAY UPI
function payUPI() {
    const upiId = "<%= item.upiId %>";
    const amount = "<%= item.price %>";
    const name = "PunarBazaar";

    const url = `upi://pay?pa=${upiId}&pn=${name}&am=${amount}&cu=INR`;

    alert("Complete payment and then click 'I Have Paid'");
    window.location.href = url;
}


// 🔥 BUYER MARK PAID
async function markPaid() {

    const btn = document.getElementById("markBtn");

    btn.innerText = "Processing...";
    btn.disabled = true;

    try {
        const res = await fetch(`/markPaid/<%= item._id %>`, {
            method: "POST"
        });

        const data = await res.json();

        if (data.success) {
            btn.innerText = "⏳ Waiting for Seller";
            btn.classList.add("bg-yellow-100");
        } else {
            alert("Failed ❌");
            btn.disabled = false;
        }

    } catch {
        alert("Error ❌");
        btn.disabled = false;
    }
}


// 🔥 SELLER CONFIRM
async function confirmPayment(){

    const btn = document.getElementById("confirmBtn");

    btn.innerText = "Confirming...";
    btn.disabled = true;

    try {
        const res = await fetch(`/confirmPayment/<%= item._id %>`, {
            method: "POST"
        });

        const data = await res.json();

        if(data.success){
            alert("Payment confirmed ✅");
            location.reload();
        } else {
            alert("No pending payments");
            btn.disabled = false;
        }

    } catch {
        alert("Error ❌");
        btn.disabled = false;
    }
}


// COPY
function copyNumber(phone) {
    navigator.clipboard.writeText(phone);
    alert("Number copied!");
}

</script>


</body>

</html>