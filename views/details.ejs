<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>
    <%= item.name %>
</title>

<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

</head>

<body class="bg-gradient-to-br from-slate-100 via-indigo-50 to-slate-200 min-h-screen">

<div class="max-w-7xl mx-auto px-4 py-8">

    <!-- NAV -->
    <div class="flex justify-between items-center mb-8">
        <h1 class="text-xl font-bold text-indigo-600 tracking-wide">PunarBazaar</h1>
        <a href="/" class="text-sm text-gray-600 hover:text-indigo-600 transition">← Back</a>
    </div>

    <!-- MAIN GRID -->
    <div class="grid lg:grid-cols-2 gap-10">

        <!-- IMAGE -->
        <div class="bg-white/70 backdrop-blur-lg rounded-3xl shadow-xl p-4 hover:shadow-2xl transition">

            <div class="h-[420px] overflow-hidden rounded-2xl group">
                <% if(item.image){ %>
                    <img src="<%= item.image %>"
                        class="w-full h-full object-cover group-hover:scale-110 transition duration-500">
                        <% } else { %>
                    <div class="flex items-center justify-center h-full text-gray-400">
                        No Image
                    </div>
                    <% } %>
            </div>

        </div>

        <!-- DETAILS -->
        <div class="space-y-6">

            <div>
                <h1 class="text-3xl font-bold text-gray-800">
                    <%= item.name %>
                </h1>
                <p class="text-3xl font-bold text-emerald-600 mt-2">₹ <%= item.price %>
                </p>
                </div>

            <p class="text-gray-600 leading-relaxed text-sm">
                <%= item.desc %>
            </p>

            <!-- DELETE BUTTON -->
            <% if(isOwner){ %>
                <a href="/delete/<%= item._id %>" class="inline-flex items-center gap-2 bg-red-500 text-white px-4 py-2 rounded-lg 
                           hover:bg-red-600 hover:scale-105 transition shadow-md">
                    🗑 Delete
                </a>
                <% } %>
            
                    <!-- UNLOCK CARD -->
                    <div class="bg-white/80 backdrop-blur-md border rounded-2xl p-6 shadow-lg hover:shadow-xl transition">

                <% if(!isUnlocked){ %>

                <div class="flex justify-between items-center mb-2">
                    <p class="font-medium text-gray-700">Unlock seller contact</p>
                    <span class="text-xs bg-indigo-100 text-indigo-600 px-2 py-1 rounded">
                        Secure
                    </span>
                </div>

                <p class="text-xs text-gray-500 mb-4">
                    Pay ₹5 to access verified contact details
                </p>

                <button id="payBtn" class="w-full py-3 rounded-xl text-white font-semibold
                                    bg-gradient-to-r from-indigo-600 to-purple-600
                                    hover:scale-[1.03] active:scale-[0.97]
                                    transition duration-200 shadow-lg">

                    🔓 Unlock Contact • ₹5
                </button>

                <% } else { %>

                <div class="bg-green-50 border border-green-200 p-4 rounded-xl animate-fadeIn">
                    <p class="text-green-700 font-medium">Contact Unlocked</p>
                    <p class="text-lg font-bold mt-1">
                        <%= item.user.phone %>
                    </p>
                </div>

                <% } %>

            </div>

            <!-- WHATSAPP -->
            <% if(isUnlocked){ %>
            <a href="https://wa.me/<%= item.user.phone %>" class="block text-center bg-green-600 text-white py-3 rounded-xl
                           hover:bg-green-700 hover:scale-[1.02] transition shadow-lg">
                💬 Chat on WhatsApp
            </a>
            <% } %>

            <!-- SELLER CARD -->
            <div class="bg-white rounded-2xl p-5 shadow-md hover:shadow-xl transition">

                <h2 class="font-semibold text-gray-800 mb-2">Seller Info</h2>

                <p class="font-medium">
                    <%= item.user.name %>
                </p>
                <p class="text-xs text-gray-500">
                    <%= item.user.college %> • <%= item.user.branch %>
                </p>

                <div class="flex gap-2 mt-3">
                    <span class="bg-indigo-100 text-indigo-600 px-3 py-1 rounded text-xs">
                        Trust: <%= item.user.trustScore %>
                    </span>

                    <% if(item.user.isVerified){ %>
                    <span class="bg-green-100 text-green-600 px-3 py-1 rounded text-xs">
                        ✔ Verified
                    </span>
                    <% } %>
                </div>

            </div>

        </div>

    </div>

</div>

<!-- ANIMATION -->
<style>
    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-fadeIn {
        animation: fadeIn 0.4s ease-in-out;
    }
</style>

<!-- RAZORPAY -->
<script>
    document.getElementById("payBtn")?.addEventListener("click", async () => {

    const res = await fetch("/unlock/<%= item._id %>", { method: "POST" });
    const order = await res.json();

    const options = {
        key: "<%= razorpayKey %>",
        amount: order.amount,
        currency: "INR",
        order_id: order.id,

        handler: async function (response) {

    if (!response.razorpay_order_id || !response.razorpay_signature) {
        alert("Payment incomplete ❌");
        return;
    }

            const verify = await fetch("/verifyPayment", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    razorpay_order_id: response.razorpay_order_id,
                    razorpay_payment_id: response.razorpay_payment_id,
                    razorpay_signature: response.razorpay_signature,
                })
            });

            const data = await verify.json();

            if (data.success) {
                location.reload();
            } else {
                alert("Payment failed");
            }
        }
    };

    new Razorpay(options).open();
});
</script>

</body>
</html>