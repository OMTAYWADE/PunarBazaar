<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Item Details</title>
<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-gray-50">

<div class="max-w-6xl mx-auto mt-8 px-4">

<!-- GRID -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-6">

    <!-- LEFT: IMAGE -->
    <div class="bg-white p-4 rounded-lg border">

        <div class="h-80 bg-gray-100 flex items-center justify-center rounded overflow-hidden">
            <% if(item.image){ %>
                <img src="<%= item.image %>" class="w-full h-full object-cover">
            <% } else { %>
                <span class="text-gray-400">No Image</span>
            <% } %>
        </div>

    </div>

    <!-- RIGHT: DETAILS -->
    <div class="bg-white p-6 rounded-lg border">

        <!-- TITLE -->
        <h1 class="text-xl font-semibold text-gray-800 mb-2">
            <%= item.name %>
        </h1>

        <!-- PRICE -->
        <p class="text-2xl font-bold text-green-600 mb-3">
            ₹ <%= item.price %>
        </p>

        <!-- DESCRIPTION -->
        <p class="text-gray-600 text-sm mb-4">
            <%= item.desc %>
        </p>

        <!-- UNLOCK BOX -->
        <div class="bg-gray-100 p-4 rounded mb-4">

            <% if(!isUnlocked){ %>

                <p class="text-sm text-gray-700 mb-2">
                    Unlock seller contact to proceed
                </p>

                <button id="unlockBtn"
                class="bg-indigo-600 text-white px-4 py-2 rounded w-full hover:bg-indigo-700 transition">
                    Unlock Contact (₹5)
                </button>

            <% } else { %>

                <p class="text-green-600 font-medium">
                    Contact: <%= item.user.phone %>
                </p>

            <% } %>

        </div>

        <!-- WHATSAPP -->
        <% if(isUnlocked){ %>

        <%
        let message = `Hello, I am interested in your item "${item.name}" listed for ₹${item.price}. Is it available?`;
        %>

        <a href="https://wa.me/<%= item.user?.phone %>?text=<%= encodeURIComponent(message) %>"
        class="block bg-green-600 text-white text-center p-3 rounded hover:bg-green-700 transition">
            Contact via WhatsApp
        </a>

        <% } %>

        <!-- SELLER -->
        <div class="mt-6 border-t pt-4">

            <h2 class="font-semibold text-gray-700 mb-2">
                Seller Information
            </h2>

            <p class="text-sm">Name: <%= item.user.name %></p>
            <p class="text-sm">College: <%= item.user.college %></p>
            <p class="text-sm">Branch: <%= item.user.branch %></p>

            <div class="mt-2 flex items-center gap-2 text-sm">
                <span>Trust Score: <%= item.user.trustScore %></span>

                <% if(item.user.isVerified){ %>
                    <span class="bg-green-100 text-green-700 px-2 py-1 rounded text-xs">
                        Verified
                    </span>
                <% } %>
            </div>

        </div>

    </div>

</div>

<!-- RECOMMENDED -->
<div class="mt-10">

    <h2 class="text-lg font-semibold text-gray-700 mb-4">
        Recommended Items
    </h2>

    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">

    <% recommended.forEach(r => { %>

        <div class="bg-white border p-3 rounded hover:shadow-md transition">

            <p class="text-sm font-medium truncate"><%= r.name %></p>
            <p class="text-green-600 text-sm">₹ <%= r.price %></p>

            <a href="/item/<%= r._id %>" class="text-indigo-600 text-xs">
                View
            </a>

        </div>

    <% }) %>

    </div>

</div>

</div>

<!-- RAZORPAY -->

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

<script>
document.getElementById("unlockBtn")?.addEventListener("click", async function () {

    const res = await fetch("/unlock/<%= item._id %>", { method: "POST" });
    const order = await res.json();

    const options = {
        key: "<%= razorpayKey %>",
        amount: order.amount,
        currency: "INR",
        order_id: order.id,

        handler: async function (response) {

            const verify = await fetch("/verify-payment", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    ...response,
                    itemId: "<%= item._id %>"
                })
            });

            const data = await verify.json();

            if (data.success) {
                location.reload();
            }
        }
    };

    const rzp = new Razorpay(options);
    rzp.open();
});
</script>

</body>
</html>
