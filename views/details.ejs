<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= item.name %>
    </title>

    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>

</head>

<body class="bg-gradient-to-br from-slate-100 via-indigo-50 to-slate-200 min-h-screen">

    <div class="max-w-6xl mx-auto px-4 py-8">

        <!-- NAV -->
        <div class="flex justify-between items-center mb-8">
            <h1 class="text-xl font-bold text-indigo-600">PunarBazaar</h1>
            <a href="/" class="text-sm text-gray-600 hover:text-indigo-600">← Back</a>
        </div>

        <!-- GRID -->
        <div class="grid md:grid-cols-2 gap-10">

            <!-- IMAGE -->
            <div class="bg-white rounded-2xl shadow p-4">
                <% if(item.image){ %>
                    <img src="<%= item.image %>" class="w-full h-[320px] object-cover">
                    <% } else { %>
                        <div class="h-96 flex items-center justify-center text-gray-400">
                            No Image
                        </div>
                        <% } %>
            </div>

            <!-- DETAILS -->
            <div class="bg-white/80 backdrop-blur-xl p-5 rounded-2xl shadow-sm space-y-4">

                <div>
                    <h1 class="text-2xl font-semibold text-gray-800">
                        <%= item.name %>
                    </h1>
                    <p class="text-green-600 text-xl font-bold">₹ <%= item.price %>
                    </p>
                </div>

                <p class="text-gray-500 text-sm">
                    <%= item.desc %>
                </p>
                <hr class="border-gray-200">

                <!-- CONTACT (FREE) -->
                <div class="bg-green-50 border border-green-200 rounded-xl p-4 space-y-3">

                    <div class="flex justify-between items-center">
                        <div>
                            <p class="text-xs text-gray-500">Seller</p>
                            <p class="font-semibold text-gray-800">Verified Student</p>
                            <p class="text-xs text-gray-500">College Verified ✔</p>
                        </div>

                        <span class="text-green-600 text-xs font-medium">
                            Trusted
                        </span>
                    </div>

                    <!-- CONTACT -->
                    <div class="bg-white rounded-lg border p-3">
                        <p class="text-xs text-gray-500">Contact</p>
                        <p class="text-base font-semibold text-gray-800">
                            📞 <%= item.user.phone %>
                        </p>
                    </div>

                </div>


                <!-- BUY BUTTON -->
                <% if(isUnlocked){ %>

                    <button
                        class="w-full py-3 bg-green-600 text-white rounded-xl text-lg font-semibold cursor-not-allowed opacity-90">
                        ✅ Purchased
                    </button>

                    <p class="text-green-600 text-sm text-center mt-2">
                        You already own this item
                    </p>

                    <% } else { %>

                        <button id="buyBtn" class="w-full py-3 rounded-xl text-white font-medium
bg-gradient-to-r from-indigo-600 to-indigo-500
hover:scale-[1.02] transition shadow-md">
                            🛒 Buy Item
                        </button>
                        <p class="text-xs text-gray-400 text-center">
                            🔒 Safe deal • Meet in campus • Verify before paying
                        </p>

                        <% } %>

                            <% if(isOwner){ %>
                                <button id="deleteBtn"
class="w-full py-2 rounded-xl text-red-500 font-medium
bg-red-50 hover:bg-red-100 transition">
🗑 Delete Item
</button>
                                <% } %>

                                    <!-- WHATSAPP -->
                                    <div class="flex gap-2">

                                        <!-- WhatsApp -->
                                        <a href="https://wa.me/<%= item.user.phone %>?text=Hi, I am interested in your item"
                                            target="_blank"
                                            class="flex-1 text-center py-2.5 rounded-xl bg-green-500 text-white font-medium hover:bg-green-600 transition">
                                            💬 WhatsApp
                                        </a>

                                        <!-- Copy -->
                                        <button onclick="copyNumber('<%= item.user.phone %>')"
                                            class="flex-1 py-2.5 rounded-xl bg-gray-100 text-gray-700 hover:bg-gray-200 transition">
                                            📋 Copy
                                        </button>

                                    </div>

            </div>
        </div>

    </div>

    <!-- SCRIPT -->

    <script>
        function copyNumber(phone) {
            navigator.clipboard.writeText(phone);
            showToast("Number copied!");
        }

        document.addEventListener("DOMContentLoaded", () => {

            const btn = document.getElementById("buyBtn");

            if (!btn) return;

            btn.addEventListener("click", async () => {

                console.log("BUY CLICKED 🛒");

                try {
                    btn.innerHTML = "⏳ Processing...";
                    btn.disabled = true;
                    btn.classList.add("opacity-70");
                    // CREATE ORDER
                    const res = await fetch("https://punarbazaar.onrender.com/createOrder/<%= item._id %>", {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json",
                            "Authorization": "Bearer " + localStorage.getItem("token")
                        }
                    });

                    const data = await res.json();
                    console.log("ORDER:", data);

                    const order = data.order;

                    // RAZORPAY OPTIONS
                    const options = {
                        key: "rzp_test_SVtLWAFVv9iBtk",
                        amount: order.amount,
                        currency: "INR",
                        order_id: order.id,
                        name: "PunarBazaar",
                        description: "Purchase Item",
                        theme: { color: "#4f46e5" },

                        handler: async function (response) {

                            console.log("PAYMENT SUCCESS:", response);
                            console.log('payment id: ', response.razorpay_payment_id);
                            console.log('order id: ', response.razorpay_order_id);
                            console.log('signature: ', response.razorpay_signature);


                            // VERIFY PAYMENT
                            const verify = await fetch("https://punarbazaar.onrender.com/verifyPayment", {
                                method: "POST",
                                headers: {
                                    "Content-Type": "application/json",
                                },

                                body: JSON.stringify({
                                    razorpay_order_id: response.razorpay_order_id,
                                    razorpay_payment_id: response.razorpay_payment_id,
                                    razorpay_signature: response.razorpay_signature,
                                    itemId: "<%= item._id %>"
                                })
                            });

                            const data2 = await verify.json();
                            console.log("VERIFY BODY:", data2);

                            if (data2.success) {
                                alert("✅ Purchase Successful!");

                                btn.innerText = "Purchased ✅";
                                btn.disabled = true;

                                btn.classList.remove("bg-indigo-600", "hover:bg-indigo-700");
                                btn.classList.add("bg-green-600", "cursor-not-allowed");

                            } else {
                                alert("❌ Payment verification failed");
                            }
                        }
                    };

                    const rzp = new Razorpay(options);
                    rzp.open();

                } catch (err) {
                    console.error("ERROR:", err);
                    alert("Something went wrong ❌");
                }
            });

        });

        const deleteBtn = document.getElementById("deleteBtn");

        if (deleteBtn) {
            deleteBtn.addEventListener("click", async () => {

                const confirmDelete = confirm("Are you sure you want to delete this item?");

                if (!confirmDelete) return;

                try {
                    const res = await fetch(`https://punarbazaar.onrender.com/item/<%= item._id %>`, {
                        method: "DELETE",
                        headers: {
                            "Authorization": "Bearer " + localStorage.getItem("token")
                        }
                    });

                    if (res.ok) {
                        alert("Item deleted successfully ✅");
                        window.location.href = "/";
                    } else {
                        alert("Failed to delete ❌");
                    }

                } catch (err) {
                    console.error(err);
                    alert("Error deleting item ❌");
                }
            });
        }
    </script>


</body>

</html>