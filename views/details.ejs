<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= item.name %></title>

<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

</head>

<body class="bg-gradient-to-br from-slate-100 via-indigo-50 to-slate-200 min-h-screen">

<div class="max-w-6xl mx-auto px-4 py-8">

```
<!-- NAV -->
<div class="flex justify-between items-center mb-8">
    <h1 class="text-xl font-bold text-indigo-600">PunarBazaar</h1>
    <a href="/" class="text-sm text-gray-600 hover:text-indigo-600">← Back</a>
</div>

<!-- GRID -->
<div class="grid md:grid-cols-2 gap-10">

    <!-- IMAGE -->
    <div class="bg-white rounded-2xl shadow p-4">
        <% if(item.image){ %>
            <img src="<%= item.image %>" class="w-full h-96 object-cover rounded-xl">
        <% } else { %>
            <div class="h-96 flex items-center justify-center text-gray-400">
                No Image
            </div>
        <% } %>
    </div>

    <!-- DETAILS -->
    <div class="space-y-6">

        <div>
            <h1 class="text-3xl font-bold"><%= item.name %></h1>
            <p class="text-2xl text-green-600 font-bold mt-2">₹ <%= item.price %></p>
        </div>

        <p class="text-gray-600"><%= item.desc %></p>

        <!-- UNLOCK CARD -->
        <div class="bg-white rounded-2xl p-6 shadow">

            <!-- LOCKED -->
            <div id="lockedUI" class="<%= isUnlocked ? 'hidden' : '' %>">

                <p class="font-medium mb-2">Unlock seller contact</p>
                <p class="text-sm text-gray-500 mb-4">Pay ₹5 to view contact</p>

                <button id="payBtn"
                    class="w-full py-3 bg-indigo-600 text-white rounded-xl hover:bg-indigo-700 transition">
                    🔓 Unlock Contact
                </button>

            </div>

            <!-- UNLOCKED -->
            <div id="unlockedUI" class="<%= !isUnlocked ? 'hidden' : '' %>">

                <div class="bg-green-50 p-4 rounded-xl border border-green-200">
                    <p class="text-green-700 font-semibold">Contact Unlocked ✅</p>
                    <p class="text-lg font-bold mt-1"><%= item.user.phone %></p>
                </div>

            </div>

        </div>

        <!-- WHATSAPP -->
        <% if(isUnlocked){ %>
        <a href="https://wa.me/<%= item.user.phone %>"
            class="block text-center bg-green-600 text-white py-3 rounded-xl hover:bg-green-700">
            💬 Chat on WhatsApp
        </a>
        <% } %>

    </div>
</div>
```

</div>

<!-- SCRIPT -->

<script>
document.addEventListener("DOMContentLoaded", () => {

    const btn = document.getElementById("payBtn");
    const lockedUI = document.getElementById("lockedUI");
    const unlockedUI = document.getElementById("unlockedUI");

    console.log("BTN:", btn);

    if (!btn) return;

    btn.addEventListener("click", async () => {

        console.log("CLICKED 🔥");

        try {
            // CREATE ORDER
            const res = await fetch("https://punarbazaar-production.up.railway.app/unlock/<%= item._id %>", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "Authorization": "Bearer " + localStorage.getItem("token")
                },
                body: JSON.stringify({ amount: 5 })
            });

            const order = await res.json();
            console.log("ORDER:", order);

            // RAZORPAY
            const options = {
                key: "rzp_test_SVtLWAFVv9iBtk",
                amount: order.amount,
                currency: "INR",
                order_id: order.id,

                handler: async function (response) {

                    console.log("PAYMENT SUCCESS:", response);

                    // VERIFY
                    const verify = await fetch("https://punarbazaar-production.up.railway.app/verifyPayment", {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json",
                            "Authorization": "Bearer " + localStorage.getItem("token")
                        },
                        body: JSON.stringify({
                            ...response,
                            blogId: "<%= item._id %>"
                        })
                    });

                    const data = await verify.json();
                    console.log("VERIFY:", data);

                    if (data.success || data.message === "Payment successful") {

                        // UPDATE UI
                        lockedUI.classList.add("hidden");
                        unlockedUI.classList.remove("hidden");

                    } else {
                        alert("Payment failed ❌");
                    }
                }
            };

            const rzp = new Razorpay(options);
            rzp.open();

        } catch (err) {
            console.error("ERROR:", err);
        }
    });

});
</script>

</body>
</html>
