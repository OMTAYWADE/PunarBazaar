<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= item.name %></title>

<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-gradient-to-br from-slate-100 via-indigo-50 to-slate-200 min-h-screen">

<div class="max-w-6xl mx-auto px-4 py-8">

<!-- NAV -->
<div class="flex justify-between items-center mb-8">
    <h1 class="text-xl font-bold text-indigo-600">PunarBazaar</h1>
    <a href="/" class="text-sm text-gray-600 hover:text-indigo-600">← Back</a>
</div>

<div class="grid md:grid-cols-2 gap-10">

<!-- IMAGE -->
<div class="bg-white rounded-2xl shadow p-4">
    <% if(item.image){ %>
        <img src="<%= item.image %>" class="w-full h-[320px] object-cover rounded-xl">
    <% } else { %>
        <div class="h-80 flex items-center justify-center text-gray-400">
            No Image
        </div>
    <% } %>
</div>

<!-- DETAILS -->
<div class="space-y-5">

<!-- TITLE -->
<div class="bg-white p-5 rounded-2xl shadow">
    <h1 class="text-2xl font-semibold text-gray-800"><%= item.name %></h1>
    <p class="text-green-600 text-xl font-bold mt-1">₹ <%= item.price %></p>
    <p class="text-gray-500 text-sm mt-2"><%= item.desc %></p>
</div>

<!-- SELLER -->
<div class="bg-green-50 border border-green-200 rounded-2xl p-4 space-y-3">
    <div class="flex justify-between">
        <div>
            <p class="text-xs text-gray-500">Seller</p>
            <p class="font-semibold text-gray-800">Verified Student</p>
            <p class="text-xs text-gray-500">College Verified ✔</p>
        </div>

        <span class="text-green-600 text-xs font-semibold">
            ⭐ Trust: <%= item.user?.trustScore || 0 %>
        </span>
    </div>

    <div class="bg-white border rounded-lg p-3">
        <p class="text-xs text-gray-500">Contact</p>
        <p class="font-semibold text-gray-800">
            📞 <%= item.user?.phone || "not available" %>
        </p>
    </div>
</div>

<!-- DEAL CARD -->
<div class="bg-white rounded-2xl shadow-lg p-6 space-y-5 border">

    <!-- HEADER -->
    <div class="flex justify-between items-center">
        <h2 class="text-lg font-semibold">Deal Progress</h2>
        <span class="text-xs px-3 py-1 rounded-full bg-gray-100">
            <%= unlock?.status?.toUpperCase() || "NOT STARTED" %>
        </span>
    </div>

    <!-- FLOW -->
    <% if(!unlock){ %>

        <button onclick="createOrder()" 
        class="w-full py-3 bg-indigo-600 text-white rounded-xl font-semibold">
            🚀 Start Deal
        </button>

    <% } else if(unlock.status === "pending"){ %>

        <div class="bg-indigo-50 border p-4 rounded-xl">
            <p class="text-sm font-medium">Pay using UPI</p>

            <div class="flex justify-between mt-2 bg-white p-2 rounded border">
                <span><%= item.upiId %></span>
                <button onclick="copyUPI('<%= item.upiId %>')" class="text-xs">Copy</button>
            </div>

            <p class="text-xs mt-2 text-gray-500">₹ <%= item.price %></p>
        </div>

        <button onclick="payUPI()" class="w-full py-3 bg-green-600 text-white rounded-xl">
            Open UPI App
        </button>

        <button id="markBtn" onclick="markPaid()" class="w-full py-2 border rounded-xl">
            I Have Paid
        </button>

    <% } else if(unlock.status === "paid"){ %>

        <div class="bg-yellow-50 p-4 rounded-xl text-sm text-yellow-700">
            ⏳ Waiting for seller confirmation
        </div>

    <% } else if(unlock.status === "confirmed"){ %>

        <div class="bg-green-50 p-4 rounded-xl text-green-700">
            ✅ Deal Completed
        </div>

        <% if(!unlock.buyerRated){ %>
            <button onclick="rateSeller()" class="w-full py-3 bg-indigo-600 text-white rounded-xl">
                ⭐ Rate Seller
            </button>
        <% } else { %>
            <p class="text-green-600 text-center">⭐ Already Rated</p>
        <% } %>

    <% } %>

</div>

<!-- ACTIONS -->
<div class="flex gap-2">
<a href="https://wa.me/<%= item.user.phone %>?text=Hi, interested"
class="flex-1 text-center py-2.5 rounded-xl bg-green-500 text-white">
💬 WhatsApp
</a>

<button onclick="copyNumber('<%= item.user.phone %>')"
class="flex-1 py-2.5 rounded-xl bg-gray-100">
📋 Copy
</button>
</div>

<!-- OWNER -->
<% if(isOwner){ %>
<button onclick="confirmPayment()" 
class="w-full py-3 bg-indigo-600 text-white rounded-xl">
✅ Confirm Payment
</button>
<% } %>

</div>
</div>
</div>

<script>

// UPI
function payUPI(){
    const upi = "<%= item.upiId %>";
    const amount = "<%= item.price %>";
    window.location.href = `upi://pay?pa=${upi}&pn=PunarBazaar&am=${amount}&cu=INR`;
}

// COPY
function copyUPI(id){
    navigator.clipboard.writeText(id);
    alert("Copied");
}

function copyNumber(num){
    navigator.clipboard.writeText(num);
    alert("Copied");
}

// CREATE ORDER
async function createOrder(){
    const res = await fetch(`/createOrder/<%= item._id %>`, {
        method: "POST",
        credentials: "include"
    });
    const data = await res.json();
    if(data.success) location.reload();
}

// MARK PAID
async function markPaid(){
    const res = await fetch(`/markPaid/<%= item._id %>`, {
        method: "POST",
        credentials: "include"
    });
    const data = await res.json();
    if(data.success) location.reload();
}

// CONFIRM
async function confirmPayment(){
    const res = await fetch(`/confirmPayment/<%= item._id %>`, {
        method: "POST",
        credentials: "include"
    });
    const data = await res.json();
    if(data.success) location.reload();
}

// RATE
async function rateSeller(){
    const rating = prompt("Rate 1-5");
    if(!rating) return;

    const res = await fetch(`/rate/<%= item._id %>`, {
        method: "POST",
        headers: {"Content-Type":"application/json"},
        body: JSON.stringify({rating}),
        credentials: "include"
    });

    const data = await res.json();
    if(data.success) location.reload();
}

</script>

</body>
</html>