<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= item.name %> - PunarBazaar</title>
<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-slate-50">

<!-- NAVBAR -->
<div class="bg-white border-b sticky top-0 z-50">
    <div class="max-w-7xl mx-auto flex justify-between items-center p-4">
        <h1 class="text-lg font-bold text-indigo-600">PunarBazaar</h1>
        <a href="/" class="text-sm text-gray-600 hover:text-indigo-600">← Back</a>
    </div>
</div>

<div class="max-w-6xl mx-auto mt-8 px-4">

<!-- GRID -->
<div class="grid md:grid-cols-2 gap-8">

    <!-- IMAGE -->
    <div class="bg-white rounded-2xl shadow-md border p-4">

        <div class="h-96 bg-gray-100 rounded-xl overflow-hidden flex items-center justify-center">

            <% if(item.image){ %>
                <img src="<%= item.image %>" 
                class="w-full h-full object-cover hover:scale-105 transition duration-500">
            <% } else { %>
                <span class="text-gray-400">No Image</span>
            <% } %>

        </div>

    </div>

    <!-- DETAILS -->
    <div>

        <!-- TITLE -->
        <h1 class="text-2xl font-semibold text-gray-800 mb-2">
            <%= item.name %>
        </h1>

        <!-- PRICE -->
        <p class="text-3xl font-bold text-emerald-600 mb-4">
            ₹ <%= item.price %>
        </p>

        <!-- DESCRIPTION -->
        <p class="text-gray-600 text-sm leading-relaxed mb-6">
            <%= item.desc %>
        </p>

        <!-- 🔥 UNLOCK SECTION -->
        <div class="rounded-2xl p-5 mb-6 border 
        bg-gradient-to-br from-white to-indigo-50 shadow-md">

            <% if(!isUnlocked){ %>

                <div class="flex justify-between items-center mb-2">
                    <p class="text-sm font-medium text-gray-700">
                        Unlock seller contact
                    </p>

                    <span class="text-xs bg-indigo-100 text-indigo-600 px-2 py-1 rounded">
                        Secure
                    </span>
                </div>

                <p class="text-xs text-gray-500 mb-4">
                    Pay ₹5 to access verified contact details
                </p>

                <button id="unlockBtn"
                class="w-full bg-gradient-to-r from-indigo-600 to-purple-600 
                text-white py-3 rounded-xl font-semibold 
                shadow-md hover:shadow-lg hover:scale-[1.02] transition">

                    🔓 Unlock Contact • ₹5

                </button>

            <% } else { %>

                <div class="bg-green-50 border border-green-200 p-4 rounded-xl">

                    <p class="text-sm text-green-700 font-medium mb-1">
                        Contact Unlocked
                    </p>

                    <p class="text-lg font-semibold text-gray-800">
                        <%= item.user.phone %>
                    </p>

                </div>

            <% } %>

        </div>

        <!-- WHATSAPP -->
        <% if(isUnlocked){ %>

        <%
        let message = `Hello, I am interested in your item "${item.name}" listed for ₹${item.price}. Is it available?`;
        %>

        <a href="https://wa.me/<%= item.user?.phone %>?text=<%= encodeURIComponent(message) %>"
        class="block bg-green-600 text-white text-center py-3 rounded-xl font-medium 
        hover:bg-green-700 transition mb-6">
            Chat on WhatsApp
        </a>

        <% } %>

        <!-- SELLER INFO -->
        <div class="bg-white border rounded-xl p-5 shadow-sm">

            <h2 class="font-semibold text-gray-800 mb-3">
                Seller Information
            </h2>

            <p class="text-sm font-medium">
                <%= item.user.name %>
            </p>

            <p class="text-xs text-gray-500">
                <%= item.user.college %> • <%= item.user.branch %>
            </p>

            <div class="mt-4 flex gap-3 items-center">

                <span class="bg-indigo-100 text-indigo-700 px-3 py-1 rounded text-xs">
                    Trust Score: <%= item.user.trustScore %>
                </span>

                <% if(item.user.isVerified){ %>
                    <span class="bg-green-100 text-green-700 px-3 py-1 rounded text-xs">
                        ✔ Verified
                    </span>
                <% } %>

            </div>

        </div>

    </div>

</div>

<!-- RECOMMENDED -->
<div class="mt-12">

    <h2 class="text-lg font-semibold text-gray-800 mb-4">
        Recommended Items
    </h2>

    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-5">

    <% recommended.forEach(r => { %>

        <div class="bg-white border rounded-xl overflow-hidden hover:shadow-md transition">

            <div class="h-32 bg-gray-100 flex items-center justify-center">
                <% if(r.image){ %>
                    <img src="<%= r.image %>" class="w-full h-full object-cover">
                <% } %>
            </div>

            <div class="p-3">

                <p class="text-sm font-medium truncate">
                    <%= r.name %>
                </p>

                <p class="text-emerald-600 text-sm font-semibold">
                    ₹ <%= r.price %>
                </p>

                <a href="/item/<%= r._id %>"
                class="text-indigo-600 text-xs hover:underline">
                    View
                </a>

            </div>

        </div>

    <% }) %>

    </div>

</div>

</div>

<!-- RAZORPAY -->
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

<script>
document.getElementById("unlockBtn")?.addEventListener("click", async function () {

    const res = await fetch("/unlock/<%= item._id %>", { method: "POST" });

    const order = await res.json();
    console.log(order);

    const options = {
        key: "<%= razorpayKey %>",
        amount: order.amount,
        currency: "INR",
        order_id: order.id,

        handler: async function (response) {

            const verify = await fetch("/verifyPayment", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    ...response,
                    itemId: "<%= item._id %>"
                })
            });

            const data = await verify.json();

            if (data.success) {
                location.reload();
            }
        }
    };

    const rzp = new Razorpay(options);
    rzp.open();
});
</script>

</body>
</html>