<!DOCTYPE html>

<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= item.name %>
    </title>

<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
<style>
    button {
        transition: all 0.25s ease;
    }

    .fade {
        animation: fadeUp 0.4s ease;
    }

    @keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

</head>

<body class="bg-gradient-to-br from-slate-100 via-indigo-50 to-slate-200 min-h-screen">

<div class="max-w-4xl mx-auto px-3 py-6 fade">

<!-- NAV -->

<div class="flex justify-between items-center mb-5">
    <h1 class="font-bold text-indigo-600 text-lg">PunarBazaar</h1>
    <a href="/" class="text-sm text-gray-500 hover:text-indigo-600">← Back</a>
    </div>

<!-- IMAGE -->
<div class="rounded-2xl overflow-hidden shadow-md bg-white">
    <% if(item.image){ %>
        <img src="<%= item.image %>" class="w-full h-64 sm:h-80 object-cover">
        <% } else { %>
        <div class="h-64 flex items-center justify-center text-gray-400">
            No Image
        </div>
        <% } %>
            </div>

<!-- DETAILS -->

<div class="mt-5 space-y-4">

    <div>
    <h1 class="text-xl font-semibold text-gray-800">
        <%= item.name %>
    </h1>

<p class="text-indigo-600 text-xl font-bold mt-1">
    ₹ <%= item.price %>
</p>

<p class="text-gray-600 text-sm mt-2">
    <%= item.desc %>
</p>

</div>

<!-- SELLER -->

<div class="bg-white rounded-xl p-4 shadow-sm flex justify-between items-center">
    <div>
        <p class="text-sm font-medium text-gray-800">Verified Seller</p>
        <p class="text-xs text-gray-500">College Verified ✔</p>
    </div>

<div class="text-right">
    <p class="text-xs text-gray-500">Trust</p>
    <p class="text-indigo-600 font-semibold">
        <%= item.user?.trustScore || 0 %>
    </p>
</div>

</div>

<!-- CONTACT -->

<div class="grid grid-cols-2 gap-3">

<a href="https://wa.me/<%= item.user.phone %>?text=<%= encodeURIComponent(`Hi, I saw your ${item.name}`) %>"
    class="py-3 text-center rounded-xl bg-green-500 text-white font-medium hover:bg-green-600">
    💬 Chat </a>

<button onclick="copyNumber('<%= item.user.phone %>')"
class="py-3 bg-indigo-600 text-white rounded-xl hover:bg-indigo-700">
📋 Copy </button>

</div>

<!-- DEAL BOX -->

<div class="bg-white rounded-xl p-4 shadow-sm space-y-4">

<div>
    <p class="text-sm font-medium text-gray-700">Deal Status</p>
    <p id="statusText" class="text-xs text-gray-500 mt-1">
        <%= unlock?.status || "not_started" %>
    </p>
</div>

<!-- UPI -->

<div id="upiBox" class="hidden bg-indigo-50 p-3 rounded-lg text-sm">
    <p class="text-gray-600">UPI ID</p>
    <div class="flex justify-between mt-1">
        <span class="font-medium">
            <%= item.upiId %>
        </span>
        <button onclick="copyUPI('<%= item.upiId %>')" class="text-indigo-600 text-xs">Copy</button>
    </div>
    <p class="text-xs mt-2 text-gray-500">Amount: ₹ <%= item.price %>
    </p>
    </div>

<!-- MAIN BUTTON -->

<button id="dealBtn" class="w-full py-3 rounded-xl text-white font-medium shadow-md">
    Loading... </button>

</div>

</div>

</div>

<script>
    const state = "<%= unlock?.status || 'not_started' %>";
    const isOwner = <%= isOwner %>;
    const itemId = "<%= item._id %>";

    const btn = document.getElementById("dealBtn");
    const upiBox = document.getElementById("upiBox");
    const statusText = document.getElementById("statusText");

    // UI update
    function setButton(text, color, disabled = false) {
        btn.innerText = text;
        btn.disabled = disabled;
        btn.className = `w-full py-3 rounded-xl text-white font-medium shadow-md ${color}`;
    }

    // INIT UI
    function initUI() {

    statusText.innerText = state.replace("_", " ");

    if (state === "not_started" && !isOwner) {
        setButton("Start Deal", "bg-indigo-600 hover:bg-indigo-700");
    }

    else if (state === "pending" && !isOwner) {
        setButton("I Paid", "bg-green-600 hover:bg-green-700");
        upiBox.classList.remove("hidden");
    }

    else if (state === "paid" && !isOwner) {
        setButton("Waiting for Seller", "bg-yellow-500", true);
    }

    else if (state === "paid" && isOwner) {
        setButton("Confirm Payment", "bg-indigo-600 hover:bg-indigo-700");
    }

    else if (state === "confirmed") {
        setButton("Deal Completed", "bg-green-600", true);
    }

    else {
        setButton("Not Available", "bg-gray-400", true);
    }
}

    // ACTION
    async function handleAction() {
        btn.disabled = true;
    btn.innerText = "Processing...";

    try {
        let url = "";

        if (state === "not_started") {
            url = `/createDeal/${itemId}`;
        }
        else if (state === "pending" && !isOwner) {
            url = `/markPaid/${itemId}`;
        }
        else if (state === "paid" && isOwner) {
            url = `/confirmPayment/${itemId}`;
        }

        if (!url) {
            btn.disabled = false;
            return;
        }

        const res = await fetch(url, {
            method:"POST",
            credentials:"include"
        });

        const data = await res.json();
        console.log(data);

        if(data.success){
            location.reload();
        } else {
            alert(data.message || "Try again");
            btn.disabled = false;
            initUI();
        }

    } catch (err) {
        console.error(err);
        btn.disabled = false;
        initUI();
    }
}

    // UTILS
    function copyUPI(id) {
        navigator.clipboard.writeText(id);
        alert("UPI Copied");
    }

    function copyNumber(num) {
        navigator.clipboard.writeText(num);
        alert("Number Copied");
    }

    // INIT
    btn.onclick = handleAction;
    initUI();
</script>

</body>

</html>