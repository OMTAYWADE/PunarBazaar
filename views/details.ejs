<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= item.name %></title>

<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-slate-50 min-h-screen">

<div class="max-w-5xl mx-auto px-3 py-5">

<!-- NAV -->
<div class="flex justify-between items-center mb-5">
    <h1 class="font-semibold text-indigo-600">PunarBazaar</h1>
    <a href="/" class="text-sm text-gray-500">← Back</a>
</div>

<!-- IMAGE -->
<div class="rounded-xl overflow-hidden bg-white">
    <% if(item.image){ %>
        <img src="<%= item.image %>" class="w-full h-60 sm:h-80 object-cover">
    <% } else { %>
        <div class="h-60 flex items-center justify-center text-gray-400">
            No Image
        </div>
    <% } %>
</div>

<!-- MAIN -->
<div class="mt-4 space-y-4">

<!-- TITLE -->
<div>
    <h1 class="text-lg sm:text-xl font-semibold text-gray-800">
        <%= item.name %>
    </h1>

    <p class="text-indigo-600 text-lg font-bold mt-1">
        ₹ <%= item.price %>
    </p>

    <p class="text-gray-500 text-sm mt-2 leading-relaxed">
        <%= item.desc %>
    </p>
</div>

<!-- SELLER -->
<div class="bg-white rounded-xl p-4 flex justify-between items-center">

    <div>
        <p class="text-sm font-medium text-gray-800">Verified Seller</p>
        <p class="text-xs text-gray-500">College Verified ✔</p>
    </div>

    <div class="text-right">
        <p class="text-xs text-gray-500">Trust</p>
        <p class="text-indigo-600 font-semibold">
            <%= item.user?.trustScore || 0 %>
        </p>
    </div>

</div>

<!-- ACTIONS -->
<div class="grid grid-cols-2 gap-3">

<a href="https://wa.me/<%= item.user.phone %>?text=<%= encodeURIComponent(`Hi, I saw your ${item.name} on Punar Bazaar and I'm interested.`) %>"
class="py-3 text-center rounded-xl bg-green-500 text-white font-medium">
💬 Chat
</a>

<button onclick="copyNumber('<%= item.user.phone %>')"
class="py-3 rounded-xl bg-white border text-gray-700">
📋 Copy
</button>

</div>

<!-- DEAL -->
<div class="bg-white rounded-xl p-4 space-y-3">

<p class="text-sm font-medium">Deal Status</p>

<p class="text-xs text-gray-500">
<%= unlock?.status || "not started" %>
</p>

<% if(!unlock){ %>

<button onclick="createOrder()"
class="w-full py-3 rounded-xl bg-indigo-600 text-white font-medium">
Start Deal
</button>

<% } else if(unlock.status==="pending"){ %>

<div class="bg-gray-50 p-3 rounded-lg text-sm">

<p>UPI ID:</p>

<div class="flex justify-between items-center mt-1">
<span class="font-medium"><%= item.upiId %></span>
<button onclick="copyUPI('<%= item.upiId %>')" class="text-xs text-indigo-600">Copy</button>
</div>

<p class="text-xs mt-2">Amount: ₹ <%= item.price %></p>

</div>

<button onclick="payUPI()" class="w-full py-3 bg-green-600 text-white rounded-xl">
Open UPI
</button>

<button onclick="markPaid()" class="w-full py-2 border rounded-xl">
I Paid
</button>

<% } else if(unlock.status==="paid"){ %>

<div class="text-yellow-600 text-sm">
Waiting for seller confirmation
</div>

<% } else if(unlock.status==="confirmed"){ %>

<div class="text-green-600 text-sm">
Deal completed
</div>

<% if(!unlock.buyerRated){ %>
<button onclick="rateSeller()" class="w-full py-3 bg-indigo-600 text-white rounded-xl">
Rate Seller
</button>
<% } %>

<% } %>

</div>

<!-- OWNER -->
<% if(isOwner){ %>
<button onclick="confirmPayment()"
class="w-full py-3 bg-indigo-600 text-white rounded-xl">
Confirm Payment
</button>
<% } %>

</div>

</div>

<script>
function payUPI(){
    const upi="<%= item.upiId %>";
    const amount="<%= item.price %>";
    window.location.href=`upi://pay?pa=${upi}&pn=PunarBazaar&am=${amount}&cu=INR`;
}

function copyUPI(id){
    navigator.clipboard.writeText(id);
    alert("Copied");
}

function copyNumber(num){
    navigator.clipboard.writeText(num);
    alert("Copied");
}

async function createOrder(){
    const res=await fetch(`/createOrder/<%= item._id %>`,{method:"POST",credentials:"include"});
    const data=await res.json();
    if(data.success) location.reload();
}

async function markPaid(){
    const res=await fetch(`/markPaid/<%= item._id %>`,{method:"POST",credentials:"include"});
    const data=await res.json();
    if(data.success) location.reload();
}

async function confirmPayment(){
    const res=await fetch(`/confirmPayment/<%= item._id %>`,{method:"POST",credentials:"include"});
    const data=await res.json();
    if(data.success) location.reload();
}

async function rateSeller(){
    const rating=prompt("Rate 1-5");
    if(!rating) return;

    const res=await fetch(`/rate/<%= item._id %>`,{
        method:"POST",
        headers:{"Content-Type":"application/json"},
        body:JSON.stringify({rating}),
        credentials:"include"
    });

    const data=await res.json();
    if(data.success) location.reload();
}
</script>

</body>
</html>