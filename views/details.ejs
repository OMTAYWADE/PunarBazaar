<!DOCTYPE html>
<html lang="en">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= item.name %></title>

<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-gradient-to-br from-slate-100 via-indigo-50 to-slate-200 min-h-screen">

<div class="max-w-6xl mx-auto px-4 py-8">

<!-- NAV -->
<div class="flex justify-between items-center mb-8">
    <h1 class="text-xl font-bold text-indigo-600">PunarBazaar</h1>
    <a href="/" class="text-sm text-gray-600 hover:text-indigo-600">← Back</a>
</div>

<!-- GRID -->
<div class="grid md:grid-cols-2 gap-10">

<!-- IMAGE -->
<div class="bg-white rounded-2xl shadow p-4">
    <% if(item.image){ %>
        <img src="<%= item.image %>" class="w-full h-[320px] object-cover rounded-xl">
    <% } else { %>
        <div class="h-80 flex items-center justify-center text-gray-400">
            No Image
        </div>
    <% } %>
</div>

<!-- DETAILS -->
<div class="bg-white/80 backdrop-blur-xl p-6 rounded-2xl shadow space-y-5">

<!-- TITLE -->
<div>
    <h1 class="text-2xl font-semibold text-gray-800"><%= item.name %></h1>
    <p class="text-green-600 text-xl font-bold mt-1">₹ <%= item.price %></p>
</div>

<!-- DESC -->
<p class="text-gray-500 text-sm"><%= item.desc %></p>

<hr>

<!-- SELLER BOX -->
<div class="bg-green-50 border border-green-200 rounded-xl p-4 space-y-3">

    <div class="flex justify-between">
        <div>
            <p class="text-xs text-gray-500">Seller</p>
            <p class="font-semibold text-gray-800">Verified Student</p>
            <p class="text-xs text-gray-500">College Verified ✔</p>
        </div>

        <span class="text-green-600 text-xs font-medium">Trusted</span>
    </div>

    <div class="bg-white border rounded-lg p-3">
        <p class="text-xs text-gray-500">Contact</p>
        <p class="font-semibold text-gray-800">
            📞 <%= item.user?.phone || "not available" %>
        </p>
        
    </div>

</div>

<!-- ACTION SECTION -->
<div class="space-y-3">
<!-- DEAL CARD -->
<div class="bg-white rounded-2xl shadow-lg p-6 space-y-5 border">

    <!-- HEADER -->
    <div class="flex justify-between items-center">
        <h2 class="text-lg font-semibold text-gray-800">Deal Progress</h2>
        <span class="text-xs px-3 py-1 rounded-full bg-gray-100 text-gray-600">
            <%= unlock ? unlock.status.toUpperCase() : "NOT STARTED" %>
        </span>
    </div>

    <!-- STEP INDICATOR -->
    <div class="flex justify-between text-xs text-gray-400">
        <span class="<%= !unlock || unlock.status==='pending' ? 'text-indigo-600 font-semibold' : '' %>">Pay</span>
        <span class="<%= unlock?.status==='paid' ? 'text-indigo-600 font-semibold' : '' %>">Waiting</span>
        <span class="<%= unlock?.status==='confirmed' ? 'text-green-600 font-semibold' : '' %>">Done</span>
    </div>

    <!-- BUYER FLOW -->
    <% if(!unlock){ %>

        <button onclick="createOrder()" 
        class="w-full py-3 bg-indigo-600 text-white rounded-xl font-semibold hover:bg-indigo-700 transition">
            🚀 Start Deal
        </button>

    <% } else if(unlock.status === "pending"){ %>

        <!-- PAYMENT BOX -->
        <div class="bg-indigo-50 border border-indigo-200 rounded-xl p-4 space-y-3">
            <p class="text-sm font-medium text-gray-700">Pay using UPI</p>

            <div class="flex justify-between items-center bg-white border rounded-lg p-3">
                <span class="text-sm font-semibold"><%= item.upiId %></span>
                <button onclick="copyUPI('<%= item.upiId %>')" 
                class="text-xs px-2 py-1 bg-gray-100 rounded">
                    Copy
                </button>
            </div>

            <p class="text-xs text-gray-500">Amount: ₹<%= item.price %></p>
        </div>

        <button onclick="payUPI()" 
        class="w-full py-3 bg-green-600 text-white rounded-xl font-semibold hover:bg-green-700">
            Open UPI App
        </button>

        <button onclick="markPaid()" 
        class="w-full py-2 border border-indigo-500 text-indigo-600 rounded-xl hover:bg-indigo-50">
            I Have Paid
        </button>

        <p class="text-xs text-center text-gray-400">
            ⚠️ Only click after actual payment
        </p>

    <% } else if(unlock.status === "paid"){ %>

        <div class="bg-yellow-50 border border-yellow-200 p-4 rounded-xl text-sm text-yellow-700">
            ⏳ Waiting for seller confirmation
        </div>

    <% } else if(unlock.status === "confirmed"){ %>

        <div class="bg-green-50 border border-green-200 p-4 rounded-xl text-sm text-green-700">
            ✅ Deal Completed Successfully
        </div>

        <% if(!unlock.buyerRated){ %>
        <button onclick="rateSeller()" 
        class="w-full py-3 bg-indigo-600 text-white rounded-xl font-semibold hover:bg-indigo-700">
            ⭐ Rate Seller
        </button>
        <% } else { %>
        <p class="text-center text-green-600 text-sm">⭐ You already rated</p>
        <% } %>

    <% } %>

</div>
<!-- SAFETY TEXT -->
<div class="text-center space-y-1 text-xs text-gray-400">
    <p>📱 Contact seller after payment</p>
    <p>🔒 Meet in campus • Verify before paying</p>
</div>

<!-- ACTIONS -->
<div class="flex gap-2">

<a href="https://wa.me/<%= item.user.phone %>?text=Hi, I am interested in your item"
target="_blank"
class="flex-1 text-center py-2.5 rounded-xl bg-green-500 text-white hover:bg-green-600 transition">
    💬 WhatsApp
</a>

<button onclick="copyNumber('<%= item.user.phone %>')"
class="flex-1 py-2.5 rounded-xl bg-gray-100 hover:bg-gray-200">
    📋 Copy
</button>

</div>

<!-- DELETE (ONLY OWNER) -->
<% if(isOwner){ %>
<button id="deleteBtn"
class="w-full py-2 rounded-xl text-red-500 bg-red-50 hover:bg-red-100 transition">
    🗑 Delete Item
</button>
<% } %>

</div>
</div>
</div>

<!-- SCRIPT -->
<script>

    
function showSuccess(msg){
    const box = document.getElementById("successBox");
    box.innerText = msg;
    box.classList.remove("hidden");

    setTimeout(() => {
        box.classList.add("hidden");
    }, 3000);
}

// UPI
function payUPI() {
       const upi = "<%= item.upiId || '' %>";
const amount = Number("<%= item.price || 0 %>");

if (!upi || !amount) {
    alert("Invalid payment details");
    return;
}

const url = `upi://pay?pa=${encodeURIComponent(upi)}&pn=PunarBazaar&am=${amount}&cu=INR`;

window.location.href = url;
}

// MARK PAID
async function markPaid() {
    const btn = document.getElementById("markBtn");
    btn.innerText = "Processing...";
    btn.disabled = true;

    const res = await fetch(`/markPaid/<%= item._id %>`, { method: "POST", credentials: "includes"});
    const data = await res.json();

    if(data.success){
        showSuccess("Payment submitted! Waiting for seller confirmation.");
        setTimeout(() => location.reload(), 2000);
    } else {
        alert("Failed ❌");
        btn.disabled = false;
    }
}

// CONFIRM PAYMENT
async function confirmPayment(){
    const btn = document.getElementById("confirmBtn");
    btn.innerText = "Confirming...";
    btn.disabled = true;

    const res = await fetch(`/confirmPayment/<%= item._id %>`, { method: "POST", credentials: "include" });
    const data = await res.json();

    if(data.success){
        showSuccess("Payment confirmed successfully!");
setTimeout(() => location.reload(), 1500);
    } else {
        alert("No pending payments");
        btn.disabled = false;
    }
}

// COPY
function copyNumber(phone){
    navigator.clipboard.writeText(phone);
    alert("Number copied!");
}

// DELETE
document.addEventListener("DOMContentLoaded", ()=>{

    const deleteBtn = document.getElementById("deleteBtn");
    if(deleteBtn){
        deleteBtn.onclick = async () => {
            if(!confirm("Delete item?")) return;

            const itemId = "<%= item._id %>";
    
            const res = await fetch(`/item/${itemId}`, { method:"DELETE", credentials: "include"});
    
            const data = await res.json();
            if(data.success){
                const card = document.getElementById(`item-${itemId}`);
                if(card){
                    card.style.transition = "0.3s";
                    card.style.opacity = "0";
                    card.style.transform = "scale(0.9)";
                    setTimeout(()=> card.remove(), 300);
                }
            }else{
                alert(data.message || "Failed ❌");
            }
    
        };
    }
})


</script>

</body>
</html>