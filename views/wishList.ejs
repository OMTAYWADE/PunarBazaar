<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>My Wishlist</title>
<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-gray-50 min-h-screen">

<!-- HEADER -->

<div class="bg-white border-b p-4">
    <h1 class="text-lg font-semibold text-gray-800 text-center">
        My Wishlist
    </h1>
</div>

<div class="max-w-6xl mx-auto mt-6 px-4">

<% if(items.length === 0){ %>

<!-- EMPTY STATE -->
<div class="text-center mt-16">

    <p class="text-gray-600 text-lg">
        Your wishlist is empty
    </p>

    <p class="text-gray-400 text-sm mt-2">
        Save items to view them later
    </p>

    <a href="/" 
    class="inline-block mt-4 bg-indigo-600 text-white px-4 py-2 rounded hover:bg-indigo-700 transition">
        Explore Items
    </a>

</div>

<% } %>

<!-- GRID -->
<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-5">

<% items.forEach(item => { %>

<div class="bg-white border rounded-lg hover:shadow-md transition overflow-hidden">

    <!-- IMAGE -->
    <div class="h-40 bg-gray-100 flex items-center justify-center">

        <% if(item.image){ %>
            <img src="<%= item.image %>" class="w-full h-full object-cover">
        <% } else { %>
            <span class="text-gray-400 text-sm">No Image</span>
        <% } %>

    </div>

    <!-- CONTENT -->
    <div class="p-3">

        <!-- NAME -->
        <h2 class="text-sm font-medium text-gray-800 truncate">
            <%= item.name %>
        </h2>

        <!-- PRICE -->
        <p class="text-green-600 font-semibold text-sm mt-1">
            ₹ <%= item.price %>
        </p>

        <!-- COLLEGE -->
        <p class="text-xs text-gray-500 mt-1">
            <%= item.user?.college || "Unknown College" %>
        </p>

        <!-- ACTIONS -->
        <div class="flex justify-between items-center mt-3">

            <a href="/item/<%= item._id %>"
            class="text-indigo-600 text-xs font-medium hover:underline">
                View
            </a>

            <a href="/wishlist/remove/<%= item._id %>"
            class="text-red-500 text-xs hover:underline">
                Remove
            </a>

        </div>

    </div>

</div>

<% }) %>

</div>


</div>

</body>
</html>
