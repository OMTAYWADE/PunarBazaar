<h1 class="text-xl font-bold mb-4">My Wishlist</h1>

<div class="grid grid-cols-2 gap-4">
<% items.forEach(item => { %>

<div class="bg-white p-3 rounded shadow">
    <h2><%= item.name %></h2>
    <p>₹ <%= item.price %></p>

    <a href="/item/<%= item._id %>" class="text-blue-500">
        View
    </a>
</div>

<% }) %>
</div>