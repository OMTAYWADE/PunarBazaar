<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>My Wishlist - PunarBazaar</title>
<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="min-h-screen bg-gradient-to-br from-slate-100 via-indigo-50 to-slate-200">

<!-- HEADER -->

<div class="bg-white/90 backdrop-blur border-b shadow-sm">
    <h1 class="text-lg font-semibold text-gray-800 text-center p-4">
        My Wishlist
    </h1>
</div>

<div class="max-w-6xl mx-auto mt-6 px-4">

<% if(items.length === 0){ %>

<!-- EMPTY STATE -->

<div class="text-center mt-20">

```
<div class="text-5xl mb-3">♡</div>

<p class="text-gray-700 text-lg font-medium">
    Your wishlist is empty
</p>

<p class="text-gray-500 text-sm mt-2">
    Save items to view them later
</p>

<a href="/" 
class="inline-block mt-5 bg-gradient-to-r from-indigo-600 to-indigo-500 text-white px-5 py-2 rounded-lg shadow hover:scale-105 transition">
    Explore Items
</a>
```

</div>

<% } %>

<!-- GRID -->

<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-6">

<% items.forEach(item => { %>

<div class="relative rounded-xl overflow-hidden group 
bg-gradient-to-br from-slate-900 to-slate-800 text-white 
shadow-md hover:shadow-2xl transition duration-300">

```
<!-- GLOW -->
<div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition 
bg-gradient-to-r from-indigo-500/10 via-purple-500/10 to-pink-500/10 blur-xl"></div>

<!-- IMAGE -->
<div class="h-44 bg-slate-800 flex items-center justify-center relative overflow-hidden">

    <% if(item.image){ %>
        <img src="<%= item.image %>" 
        class="w-full h-full object-cover group-hover:scale-110 transition duration-300">
    <% } else { %>
        <span class="text-gray-400 text-sm">No Image</span>
    <% } %>

    <!-- ❤️ REMOVE BUTTON -->
    <a href="/wishlist/remove/<%= item._id %>"
    class="absolute top-2 right-2 bg-white/10 backdrop-blur p-2 rounded-full 
    hover:scale-110 transition">
        ❤️
    </a>

</div>

<!-- CONTENT -->
<div class="p-3 relative z-10">

    <!-- NAME -->
    <h2 class="text-sm font-semibold truncate">
        <%= item.name %>
    </h2>

    <!-- PRICE -->
    <p class="text-emerald-400 font-bold text-sm mt-1">
        ₹ <%= item.price %>
    </p>

    <!-- COLLEGE -->
    <p class="text-xs text-gray-400 mt-1">
        <%= item.user?.college || "Unknown College" %>
    </p>

    <!-- BUTTON -->
    <a href="/item/<%= item._id %>"
    class="block text-center mt-3 bg-indigo-600 text-white py-1.5 rounded-lg text-sm hover:bg-indigo-700 transition">
        View Details
    </a>

</div>
```

</div>

<% }) %>

</div>

</div>

</body>
</html>
