<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Complete Profile</title>
<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-gray-50 min-h-screen flex items-center justify-center">

<!-- CARD -->

<div class="bg-white w-[90%] max-w-md p-6 rounded-lg border shadow-sm">

```
<!-- HEADER -->
<h2 class="text-lg font-semibold text-gray-800 text-center mb-2">
    Complete Your Profile
</h2>

<p class="text-sm text-gray-500 text-center mb-5">
    Add your details to start buying and selling
</p>

<!-- FORM -->
<form action="/profile" method="POST" enctype="multipart/form-data" id="profileForm">

    <!-- PHONE -->
    <div class="mb-3">
        <label class="text-xs text-gray-600">Phone Number</label>
        <input name="phone"
        class="w-full p-2 border rounded focus:ring-2 focus:ring-indigo-400 outline-none">
    </div>

    <!-- COLLEGE -->
    <div class="mb-3">
        <label class="text-xs text-gray-600">College Name</label>
        <input name="college"
        class="w-full p-2 border rounded focus:ring-2 focus:ring-indigo-400 outline-none">
    </div>

    <!-- BRANCH -->
    <div class="mb-3">
        <label class="text-xs text-gray-600">Branch</label>
        <input name="branch"
        class="w-full p-2 border rounded focus:ring-2 focus:ring-indigo-400 outline-none">
    </div>

    <!-- YEAR -->
    <div class="mb-3">
        <label class="text-xs text-gray-600">Year</label>
        <select name="year"
        class="w-full p-2 border rounded focus:ring-2 focus:ring-indigo-400 outline-none">
            <option value="">Select Year</option>
            <option value="FY">FY</option>
            <option value="SY">SY</option>
            <option value="TY">TY</option>
        </select>
    </div>

    <!-- DIVISION -->
    <div class="mb-4">
        <label class="text-xs text-gray-600">Division</label>
        <input name="division"
        class="w-full p-2 border rounded focus:ring-2 focus:ring-indigo-400 outline-none">
    </div>

    <!-- FILE -->
    <div class="mb-4">
        <label class="text-xs text-gray-600 block mb-1">
            Upload College ID
        </label>
        <input type="file" name="collegeIdImage"
        class="w-full text-sm">
    </div>

    <!-- BUTTON -->
    <button class="bg-indigo-600 text-white w-full py-2 rounded hover:bg-indigo-700 transition">
        Save Profile
    </button>

</form>

<!-- TRUST -->
<p class="text-xs text-gray-500 text-center mt-4">
    Your information is used only for verification and trust purposes.
</p>
```

</div>

<!-- LOADER -->

<div id="loader" class="fixed inset-0 bg-white hidden flex items-center justify-center">
    <p class="text-indigo-600">Saving...</p>
</div>

<script>
document.getElementById("profileForm").addEventListener("submit", () => {
    document.getElementById("loader").classList.remove("hidden");
});
</script>

</body>
</html>
