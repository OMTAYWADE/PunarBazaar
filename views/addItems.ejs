<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Add Item</title>
<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-gray-50">

<!-- HEADER -->

<div class="bg-white border-b p-4">
    <h1 class="text-lg font-semibold text-gray-700 text-center">
        Sell an Item
    </h1>
</div>

<!-- MAIN -->

<div class="max-w-2xl mx-auto mt-6 px-4">

<div class="bg-white p-6 rounded-lg border shadow-sm">

    <form action="/addItems" method="POST" enctype="multipart/form-data" id="form">

        <!-- NAME -->
        <div class="mb-4">
            <label class="block text-sm text-gray-600 mb-1">Item Name</label>
            <input name="name" 
            class="w-full p-2 border rounded focus:ring-2 focus:ring-indigo-400 outline-none"
            required>
        </div>

        <!-- PRICE -->
        <div class="mb-4">
            <label class="block text-sm text-gray-600 mb-1">Price (₹)</label>
            <input name="price" 
            class="w-full p-2 border rounded focus:ring-2 focus:ring-indigo-400 outline-none"
            required>
        </div>

        <!-- DESCRIPTION -->
        <div class="mb-4">
            <label class="block text-sm text-gray-600 mb-1">Description</label>
            <textarea name="desc" rows="3"
            class="w-full p-2 border rounded focus:ring-2 focus:ring-indigo-400 outline-none"></textarea>
        </div>

        <!-- IMAGE -->
        <div class="mb-4">
            <label class="block text-sm text-gray-600 mb-1">Upload Image</label>
            <input type="file" name="image" class="w-full text-sm">
        </div>

        <!-- CATEGORY -->
        <div class="mb-4">
            <label class="block text-sm text-gray-600 mb-1">Category</label>
            <select name="category"
            class="w-full p-2 border rounded focus:ring-2 focus:ring-indigo-400 outline-none">

                <option value="Books">Books</option>
                <option value="Electronics">Electronics</option>
                <option value="Notes">Notes</option>
                <option value="Instruments">Instruments</option>
                <option value="Others">Others</option>

            </select>
        </div>

        <!-- TYPE -->
        <div class="mb-5">
            <label class="block text-sm text-gray-600 mb-1">Item Type</label>
            <select name="type"
            class="w-full p-2 border rounded focus:ring-2 focus:ring-indigo-400 outline-none">

                <option value="note">Notes</option>
                <option value="book">Book PDF</option>
                <option value="product">Product</option>

            </select>
        </div>

        <!-- BUTTON -->
        <button class="bg-indigo-600 text-white w-full py-2 rounded hover:bg-indigo-700 transition">
            Post Item
        </button>

    </form>

</div>

</div>

<!-- LOADER -->

<div id="loader" class="fixed inset-0 bg-white hidden flex items-center justify-center">
    <p class="text-indigo-600">Posting item...</p>
</div>

<script>
document.getElementById("form").addEventListener("submit", () => {
    document.getElementById("loader").classList.remove("hidden");
});
</script>

</body>
</html>
