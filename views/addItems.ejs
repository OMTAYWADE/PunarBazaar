<!DOCTYPE html>
<html>
<head>
<title>Add Item</title>
<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

<style>
@keyframes fadeUp {
  from {opacity:0; transform:translateY(20px);}
  to {opacity:1; transform:translateY(0);}
}
.animate-fadeUp {
  animation: fadeUp 0.5s ease;
}
</style>
</head>

<body class="bg-gradient-to-br from-indigo-50 via-white to-purple-50 min-h-screen">

<div class="max-w-3xl mx-auto px-4 py-10">

<!-- HEADER -->
<div class="flex justify-between items-center mb-8">
<h2 class="text-2xl font-semibold text-gray-800">Add New Item</h2>
<a href="/" class="text-indigo-600 hover:underline">Back</a>
</div>

<!-- CARD -->
<div class="bg-white/70 backdrop-blur-xl rounded-3xl shadow-xl p-6 animate-fadeUp">

<form id="form" action="/addItems" method="POST" enctype="multipart/form-data" class="space-y-6">

<!-- NAME -->
<div>
<label class="text-sm text-gray-500">Item Name</label>
<input name="name" required
class="w-full mt-1 p-3 rounded-xl border focus:ring-2 focus:ring-indigo-500 transition">
</div>

<!-- PRICE -->
<div>
<label class="text-sm text-gray-500">Price</label>
<input type="number" name="price" required
class="w-full mt-1 p-3 rounded-xl border focus:ring-2 focus:ring-indigo-500 transition">

<p class="text-xs text-gray-400 mt-1">
💡 Fair pricing builds trust (₹5–₹200 recommended)
</p>
</div>

<!-- CATEGORY -->
<div>
<label class="text-sm text-gray-500">Category</label>
<select id="category" name="category"
class="w-full mt-1 p-3 rounded-xl border focus:ring-2 focus:ring-indigo-500">
<option>Notes</option>
<option>Books</option>
<option>Electronics</option>
<option>Other</option>
</select>
</div>

<!-- CUSTOM CATEGORY -->
<div id="customBox" class="hidden">
<input id="customCategory" placeholder="Enter custom category"
class="w-full p-3 rounded-xl border">
</div>

<!-- DESCRIPTION -->
<div>
<label class="text-sm text-gray-500">Description</label>
<textarea name="desc"
class="w-full mt-1 p-3 rounded-xl border focus:ring-2 focus:ring-indigo-500"></textarea>
</div>

<!-- IMAGE SECTION -->
<div>

<label class="text-sm text-gray-500">Upload Image</label>

<div class="flex gap-3 mt-3">

<button type="button" onclick="imgInput.click()"
class="flex-1 py-2 bg-indigo-100 text-indigo-700 rounded-xl hover:scale-105 transition">
📁 Gallery
</button>

<button type="button" onclick="cameraInput.click()"
class="flex-1 py-2 bg-green-100 text-green-700 rounded-xl hover:scale-105 transition">
📸 Camera
</button>

</div>

<input type="file" id="imgInput" name="image" class="hidden" accept="image/*">
<input type="file" id="cameraInput" class="hidden" accept="image/*" capture>

</div>

<!-- PREVIEW -->
<div id="previewBox" class="hidden">
<img id="preview"
class="w-full h-40 object-cover rounded-xl shadow transition">
</div>

<!-- SUBMIT -->
<button id="btn"
class="w-full py-3 rounded-xl text-white font-medium
bg-gradient-to-r from-indigo-600 to-purple-600
hover:scale-[1.02] active:scale-[0.97]
transition shadow-lg">
🚀 Add Item
</button>

</form>

</div>

</div>

<script>
const category = document.getElementById("category");
const customBox = document.getElementById("customBox");
const customInput = document.getElementById("customCategory");

const imgInput = document.getElementById("imgInput");
const cameraInput = document.getElementById("cameraInput");
const preview = document.getElementById("preview");
const previewBox = document.getElementById("previewBox");

const form = document.getElementById("form");
const btn = document.getElementById("btn");

// Category toggle
category.onchange = () => {
    customBox.classList.toggle("hidden", category.value !== "Other");
};

// Preview
function showPreview(file){
    if (!file) return;

    preview.src = URL.createObjectURL(file);
    previewBox.classList.remove("hidden");

    preview.classList.add("animate-fadeUp");
}

imgInput.onchange = e => showPreview(e.target.files[0]);
cameraInput.onchange = e => showPreview(e.target.files[0]);

// Submit
form.onsubmit = () => {
    if (category.value === "Other" && customInput.value.trim()) {
        category.value = customInput.value;
    }

    btn.innerText = "Uploading...";
    btn.classList.add("opacity-70");
    btn.disabled = true;
};
</script>

</body>
</html>