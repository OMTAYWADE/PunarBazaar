<!DOCTYPE html>
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Add Item</title>

<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

<style>
@keyframes fadeUp {
  from {opacity:0; transform:translateY(15px);}
  to {opacity:1; transform:translateY(0);}
}

.animate-fadeUp {
  animation: fadeUp 0.4s ease;
}

/* smoother scroll */
html {
  scroll-behavior: smooth;
}

/* prevent zoom + improve UX */
input, textarea, select {
  font-size: 16px;
}
</style>
</head>

<body class="min-h-screen bg-gradient-to-br from-indigo-50 via-white to-purple-50">

<div class="max-w-2xl mx-auto px-4 sm:px-5 py-6 sm:py-8">

<!-- HEADER -->
<div class="flex justify-between items-center mb-6">
  <div>
    <h2 class="text-xl sm:text-2xl font-bold text-indigo-600">
      Add New Item
    </h2>
    <p class="text-xs sm:text-sm text-gray-500 mt-1">
      Create a listing students will trust
    </p>
  </div>
  <a href="/" class="text-indigo-600 text-sm hover:underline">
    Back
  </a>
</div>

<!-- MESSAGE -->
<div id="msgBox" class="hidden mb-4 p-3 rounded-xl text-sm"></div>

<!-- CARD -->
<div class="bg-white rounded-xl shadow-md p-4 sm:p-5 animate-fadeUp">

<form id="form" action="/addItems" method="POST" enctype="multipart/form-data" class="space-y-5">

<!-- NAME -->
<div>
<label class="text-xs text-gray-500">Item Name</label>
<input name="name" required
class="w-full mt-1 p-2.5 sm:p-3 rounded-lg border border-gray-300
focus:ring-2 focus:ring-indigo-500 outline-none transition">
</div>

<!-- PRICE -->
<div>
<label class="text-xs text-gray-500">Price</label>
<input type="number" name="price" required
class="w-full mt-1 p-2.5 sm:p-3 rounded-lg border border-gray-300
focus:ring-2 focus:ring-indigo-500">

<p id="priceHint" class="text-xs text-gray-400 mt-1"></p>
</div>

<!-- UPI -->
<div>
<label class="text-xs text-gray-500">UPI ID</label>
<input name="upiId" required placeholder="example@upi"
class="w-full mt-1 p-2.5 sm:p-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-indigo-500">
</div>

<!-- CATEGORY -->
<div>
<label class="text-xs text-gray-500">Category</label>
<select id="category" name="category"
class="w-full mt-1 p-2.5 sm:p-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-indigo-500">
<option>Notes</option>
<option>Books</option>
<option>Electronics</option>
<option>Item-Set</option>
<option>Other</option>
</select>
</div>

<!-- CUSTOM -->
<div id="customBox" class="hidden">
<input id="customCategory" placeholder="Enter custom category"
class="w-full p-2.5 sm:p-3 rounded-lg border border-gray-300">
</div>

<!-- DESC -->
<div>
<label class="text-xs text-gray-500">Description</label>
<textarea name="desc"
class="w-full mt-1 p-2.5 sm:p-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-indigo-500"></textarea>
</div>

<!-- IMAGE -->
<div>
<label class="text-xs text-gray-500">Upload Image</label>

<div class="grid grid-cols-2 gap-2 mt-2">
<button type="button" onclick="imgInput.click()"
class="py-2 rounded-lg border hover:bg-indigo-50 active:scale-[0.97] transition">
📁 Gallery
</button>

<button type="button" onclick="cameraInput.click()"
class="py-2 rounded-lg border hover:bg-green-50 active:scale-[0.97] transition">
📸 Camera
</button>
</div>

<input type="file" id="imgInput" name="image" class="hidden" accept="image/*">
<input type="file" id="cameraInput" class="hidden" accept="image/*" capture>
</div>

<!-- PREVIEW -->
<div id="previewBox" class="hidden">
<img id="preview" class="w-full h-36 sm:h-40 object-cover rounded-lg border">
</div>

<!-- BUTTON -->
<button id="btn"
class="w-full py-2.5 sm:py-3 rounded-lg text-white font-medium
bg-indigo-600 hover:bg-indigo-700
active:scale-[0.97] transition">
Add Item
</button>

<p class="text-xs text-gray-400 text-center">
💡 Fair pricing = faster sales
</p>

</form>
</div>
</div>

<script>
const category = document.getElementById("category");
const customBox = document.getElementById("customBox");
const customInput = document.getElementById("customCategory");

const imgInput = document.getElementById("imgInput");
const cameraInput = document.getElementById("cameraInput");
const preview = document.getElementById("preview");
const previewBox = document.getElementById("previewBox");

const form = document.getElementById("form");
const btn = document.getElementById("btn");
const priceHint = document.getElementById("priceHint");

// PRICE HINT
function updatePriceHint() {
    const val = category.value;

    if (val === "Notes") priceHint.innerText = "₹5–₹50 recommended";
    else if (val === "Books") priceHint.innerText = "₹50–₹300";
    else if (val === "Electronics") priceHint.innerText = "Based on condition";
    else if (val === "Item-Set") priceHint.innerText = "Bundle pricing works best";
    else priceHint.innerText = "Keep price reasonable";
}

category.onchange = () => {
    customBox.classList.toggle("hidden", category.value !== "Other");
    updatePriceHint();
};

updatePriceHint();

// IMAGE PREVIEW
function showPreview(file){
    if (!file) return;
    preview.src = URL.createObjectURL(file);
    previewBox.classList.remove("hidden");
}

imgInput.onchange = e => showPreview(e.target.files[0]);
cameraInput.onchange = e => showPreview(e.target.files[0]);

// SUBMIT
form.onsubmit = () => {
    btn.innerHTML = `
    <span class="flex items-center justify-center gap-2">
      <span class="w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin"></span>
      Uploading...
    </span>`;
    btn.disabled = true;
};
</script>

</body>
</html>