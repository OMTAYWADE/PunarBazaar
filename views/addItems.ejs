<!DOCTYPE html>
<html>
<head>
<title>Add Item</title>
<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-gradient-to-br from-slate-100 via-indigo-50 to-slate-200 min-h-screen">

<div class="max-w-5xl mx-auto px-4 py-10">

    <!-- Header -->
    <div class="flex justify-between items-center mb-6">
        <h2 class="text-2xl font-semibold text-gray-800">Add New Item</h2>
        <a href="/" class="text-indigo-600 hover:underline">Back</a>
    </div>

    <!-- Card -->
    <div class="bg-white/90 backdrop-blur-lg border border-gray-200 rounded-2xl shadow-lg p-6">

        <form action="/addItems" method="POST" enctype="multipart/form-data" id="form">

            <!-- GRID -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

                <!-- Name -->
                <div>
                    <label class="text-sm text-gray-600">Item Name</label>
                    <input name="name" required
                    class="w-full mt-1 p-2.5 border rounded-lg focus:ring-2 focus:ring-indigo-500 transition">
                </div>

                <!-- Price -->
                <div>
                    <label class="text-sm text-gray-600">Price</label>
                    <input type="number" name="price" required
                    class="w-full mt-1 p-2.5 border rounded-lg focus:ring-2 focus:ring-indigo-500 transition">
                </div>

                <!-- Category -->
                <div>
                    <label class="text-sm text-gray-600">Category</label>
                    <select name="category"
                    class="w-full mt-1 p-2.5 border rounded-lg focus:ring-2 focus:ring-indigo-500 transition">
                        <option>Notes</option>
                        <option>Books</option>
                        <option>Electronics</option>
                    </select>
                </div>

                <!-- Image Upload -->
                <div>
                    <label class="text-sm text-gray-600">Upload Image</label>
                    <input type="file" name="image" id="imgInput"
                    class="w-full mt-1 text-sm">
                </div>

            </div>

            <!-- Description -->
            <div class="mt-5">
                <label class="text-sm text-gray-600">Description</label>
                <textarea name="desc"
                class="w-full mt-1 p-2.5 border rounded-lg focus:ring-2 focus:ring-indigo-500 transition"></textarea>
            </div>

            <!-- Image Preview -->
            <img id="preview" class="mt-4 rounded-lg hidden max-h-40 border shadow-sm">

            <!-- Submit -->
            <button id="btn"
            class="mt-6 w-full py-3 rounded-xl text-white font-medium
            bg-gradient-to-r from-indigo-600 to-indigo-500
            hover:scale-[1.02] active:scale-[0.98]
            transition duration-200 shadow-md">
                Add Item
            </button>

        </form>

    </div>

</div>

<!-- SCRIPT -->
<script>
const input = document.getElementById('imgInput');
const preview = document.getElementById('preview');
const btn = document.getElementById('btn');
const form = document.getElementById('form');

// Image preview
input.onchange = e => {
    const file = e.target.files[0];
    if (file) {
        preview.src = URL.createObjectURL(file);
        preview.classList.remove('hidden');
    }
};

// Loading state
form.onsubmit = () => {
    btn.innerText = "Uploading...";
    btn.disabled = true;
};
</script>

</body>
</html>