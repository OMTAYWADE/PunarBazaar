<!DOCTYPE html>
<html>
<head>
<title>Add Item</title>
<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

<style>
@keyframes fadeUp {
  from {opacity:0; transform:translateY(20px);}
  to {opacity:1; transform:translateY(0);}
}
.animate-fadeUp {
  animation: fadeUp 0.5s ease;
}
</style>
</head>
<body class="min-h-screen overflow-y-auto bg-gradient-to-br from-indigo-100 via-purple-100 to-blue-100">
<!-- 🌈 BACKGROUND GLOW -->
<div class="absolute inset-0 -z-10">
  <div class="absolute w-72 h-72 bg-indigo-400 opacity-30 blur-3xl top-10 left-10 rounded-full"></div>
  <div class="absolute w-72 h-72 bg-purple-400 opacity-30 blur-3xl bottom-10 right-10 rounded-full"></div>
</div>

<div class="max-w-3xl mx-auto px-4 py-10">

<!-- HEADER -->
<div class="flex justify-between items-center mb-6">
  <div>
    <h2 class="text-3xl font-bold bg-gradient-to-r from-indigo-600 to-purple-600 bg-clip-text text-transparent">
      Add New Item
    </h2>
    <p class="text-sm text-gray-500 mt-1">
      Create a listing students will trust and buy
    </p>
  </div>
  <a href="/" class="text-indigo-600 hover:underline">Back</a>
</div>

<!-- MESSAGE BOX -->
<div id="msgBox" class="hidden mb-4 p-3 rounded-xl text-sm"></div>

<!-- CARD -->
<div class="bg-white/60 backdrop-blur-2xl border border-white/40 
rounded-3xl shadow-2xl p-8 animate-fadeUp transition hover:shadow-indigo-200">

<form id="form" action="/addItems" method="POST" enctype="multipart/form-data" class="space-y-6">

<!-- NAME -->
<div>
<label class="text-sm font-medium text-gray-600">Item Name</label>
<input name="name" required
class="w-full mt-1 p-3 rounded-xl border border-gray-200 bg-white/80 
focus:ring-2 focus:ring-indigo-500 focus:border-indigo-400 
transition shadow-sm hover:shadow-md">
</div>

<!-- PRICE -->
<div>
<label class="text-sm font-medium text-gray-600">Price</label>
<input type="number" name="price" required
class="w-full mt-1 p-3 rounded-xl border border-gray-200 bg-white/80 
focus:ring-2 focus:ring-indigo-500 transition shadow-sm hover:shadow-md">

<p id="priceHint" class="text-xs text-gray-400 mt-1"></p>
</div>

<!-- CATEGORY -->
<div>
<label class="text-sm font-medium text-gray-600">Category</label>
<select id="category" name="category"
class="w-full mt-1 p-3 rounded-xl border border-gray-200 bg-white/80 focus:ring-2 focus:ring-indigo-500">
<option>Notes</option>
<option>Books</option>
<option>Electronics</option>
<option>Item-Set</option>
<option>Other</option>
</select>
</div>

<!-- CUSTOM CATEGORY -->
<div id="customBox" class="hidden">
<input id="customCategory" placeholder="Enter custom category"
class="w-full p-3 rounded-xl border border-gray-200 bg-white/80">
</div>

<!-- DESCRIPTION -->
<div>
<label class="text-sm font-medium text-gray-600">Description</label>
<textarea name="desc"
class="w-full mt-1 p-3 rounded-xl border border-gray-200 bg-white/80 focus:ring-2 focus:ring-indigo-500"></textarea>
</div>

<!-- IMAGE -->
<div>
<label class="text-sm font-medium text-gray-600">Upload Image</label>

<div class="flex gap-3 mt-3">
<button type="button" onclick="imgInput.click()"
class="flex-1 py-2 bg-white/80 border text-gray-700 rounded-xl hover:bg-indigo-50 hover:scale-105 transition shadow-sm">
📁 Gallery
</button>

<button type="button" onclick="cameraInput.click()"
class="flex-1 py-2 bg-white/80 border text-gray-700 rounded-xl hover:bg-green-50 hover:scale-105 transition shadow-sm">
📸 Camera
</button>
</div>

<input type="file" id="imgInput" name="image" class="hidden" accept="image/*">
<input type="file" id="cameraInput" class="hidden" accept="image/*" capture>
</div>

<!-- PREVIEW -->
<div id="previewBox" class="hidden">
<img id="preview"
class="w-full h-44 object-cover rounded-xl shadow-md hover:scale-[1.02] transition">
</div>

<!-- BUTTON -->
<button id="btn"
class="w-full py-3 rounded-xl text-white font-semibold
bg-gradient-to-r from-indigo-600 via-purple-600 to-pink-500
hover:scale-[1.03] active:scale-[0.97]
transition-all duration-300 shadow-lg hover:shadow-xl">
🚀 Add Item
</button>

<p class="text-xs text-gray-400 text-center mt-2">
🔒 Fair pricing increases trust and chances of sale
</p>

</form>
</div>
</div>

<script>
const category = document.getElementById("category");
const customBox = document.getElementById("customBox");
const customInput = document.getElementById("customCategory");

const imgInput = document.getElementById("imgInput");
const cameraInput = document.getElementById("cameraInput");
const preview = document.getElementById("preview");
const previewBox = document.getElementById("previewBox");

const form = document.getElementById("form");
const btn = document.getElementById("btn");
const priceHint = document.getElementById("priceHint");

// CATEGORY + PRICE HINT
function updatePriceHint() {
    const val = category.value;

    if (val === "Notes") priceHint.innerText = "💡 Recommended: ₹5 – ₹50";
    else if (val === "Books") priceHint.innerText = "💡 ₹50 – ₹300";
    else if (val === "Electronics") priceHint.innerText = "💡 Price based on condition";
    else if (val === "Item-Set") priceHint.innerText = "💡 Bundle items for better value";
    else priceHint.innerText = "💡 Keep price reasonable";
}

category.onchange = () => {
    customBox.classList.toggle("hidden", category.value !== "Other");
    updatePriceHint();
};

updatePriceHint();

// IMAGE PREVIEW
function showPreview(file){
    if (!file) return;
    preview.src = URL.createObjectURL(file);
    previewBox.classList.remove("hidden");
}

imgInput.onchange = e => showPreview(e.target.files[0]);
cameraInput.onchange = e => showPreview(e.target.files[0]);

// MESSAGE
function showMsg(message, success = true) {
    const box = document.getElementById("msgBox");

    box.innerText = message;
    box.classList.remove("hidden");

    box.className = `mb-4 p-3 rounded-xl text-sm ${
        success ? "bg-green-100 text-green-700" : "bg-red-100 text-red-700"
    }`;

    setTimeout(() => box.classList.add("hidden"), 3000);
}

// SUBMIT
form.onsubmit = (e) => {

    const name = form.name.value.trim();
    const price = Number(form.price.value);

    if (!name || !price) {
        showMsg("Please fill all fields", false);
        e.preventDefault();
        return;
    }

    if (price <= 0 || price > 2000) {
        showMsg("Price must be between ₹1–₹2000", false);
        e.preventDefault();
        return;
    }

    if (category.value === "Notes" && price > 50) {
        showMsg("Notes should be below ₹50", false);
        e.preventDefault();
        return;
    }

    if (category.value === "Other" && customInput.value.trim()) {
        category.value = customInput.value;
    }

    btn.innerHTML = `
    <span class="flex items-center justify-center gap-2">
      <span class="w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin"></span>
      Uploading...
    </span>`;
    btn.disabled = true;
};
document.querySelectorAll("input, textarea, select").forEach(el => {
    el.addEventListener("focus", () => {
        setTimeout(() => {
            el.scrollIntoView({ behavior: "smooth", block: "center" });
        }, 300);
    });
});
</script>

</body>
</html>