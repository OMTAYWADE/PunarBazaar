<!DOCTYPE html>
<html>
<head>
<title>Add Item</title>
<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

<style>
@keyframes fadeUp {
  from {opacity:0; transform:translateY(20px);}
  to {opacity:1; transform:translateY(0);}
}
.animate-fadeUp {
  animation: fadeUp 0.5s ease;
}

/* FIX MOBILE SCROLL */
html, body {
  height: 100%;
  overflow-x: hidden;
}

/* Prevent zoom on mobile */
input, textarea, select {
  font-size: 16px;
}
</style>
</head>

<body class="min-h-screen bg-gradient-to-br from-indigo-50 via-white to-purple-50">

<!-- BACKGROUND LIGHT EFFECT -->
<div class="absolute inset-0 -z-10">
  <div class="absolute w-60 h-60 bg-indigo-300 opacity-20 blur-3xl top-10 left-10 rounded-full"></div>
  <div class="absolute w-60 h-60 bg-purple-300 opacity-20 blur-3xl bottom-10 right-10 rounded-full"></div>
</div>

<div class="max-w-2xl mx-auto px-4 py-8 sm:py-10">

<!-- HEADER -->
<div class="flex justify-between items-center mb-6">
  <div>
    <h2 class="text-2xl sm:text-3xl font-bold text-indigo-600">
      Add New Item
    </h2>
    <p class="text-sm text-gray-500 mt-1">
      Create a listing students will trust
    </p>
  </div>
  <a href="/" class="text-indigo-600 hover:underline text-sm">Back</a>
</div>

<!-- MESSAGE -->
<div id="msgBox" class="hidden mb-4 p-3 rounded-xl text-sm"></div>

<!-- CARD -->
<div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5 animate-fadeUp">

<form id="form" action="/addItems" method="POST" enctype="multipart/form-data" class="space-y-5">

<!-- NAME -->
<div>
<label class="text-xs text-gray-500">Item Name</label>
<input name="name" required
class="w-full mt-1 p-3 rounded-lg border border-gray-300 bg-white
focus:ring-2 focus:ring-indigo-500 outline-none transition">
</div>

<hr class="border-gray-200">

<!-- PRICE -->
<div>
<label class="text-xs text-gray-500">Price</label>
<input type="number" name="price" required
class="w-full mt-1 p-3 rounded-lg border border-gray-300 bg-white
focus:ring-2 focus:ring-indigo-500 outline-none">

<p id="priceHint" class="text-xs text-gray-400 mt-1"></p>
</div>

<hr class="border-gray-200">

<!-- UPI Id -->
<label class="text-xs text-gray-500">UPI ID</label>
<input name="upiId" required placeholder="example@upi"
class="w-full mt-1 p-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-indigo-500">

<!-- CATEGORY -->
<div>
<label class="text-xs text-gray-500">Category</label>
<select id="category" name="category"
class="w-full mt-1 p-3 rounded-lg border border-gray-300 bg-white focus:ring-2 focus:ring-indigo-500">
<option>Notes</option>
<option>Books</option>
<option>Electronics</option>
<option>Item-Set</option>
<option>Other</option>
</select>
</div>

<!-- CUSTOM -->
<div id="customBox" class="hidden">
<input id="customCategory" placeholder="Enter custom category"
class="w-full p-3 rounded-lg border border-gray-300">
</div>

<hr class="border-gray-200">

<!-- DESC -->
<div>
<label class="text-xs text-gray-500">Description</label>
<textarea name="desc"
class="w-full mt-1 p-3 rounded-lg border border-gray-300 bg-white focus:ring-2 focus:ring-indigo-500"></textarea>
</div>

<hr class="border-gray-200">

<!-- IMAGE -->
<div>
<label class="text-xs text-gray-500">Upload Image</label>

<div class="flex gap-2 mt-2">
<button type="button" onclick="imgInput.click()"
class="flex-1 py-2 text-sm border rounded-lg hover:bg-indigo-50 transition">
📁 Gallery
</button>

<button type="button" onclick="cameraInput.click()"
class="flex-1 py-2 text-sm border rounded-lg hover:bg-green-50 transition">
📸 Camera
</button>
</div>

<input type="file" id="imgInput" name="image" class="hidden" accept="image/*">
<input type="file" id="cameraInput" class="hidden" accept="image/*" capture>
</div>

<!-- PREVIEW -->
<div id="previewBox" class="hidden">
<img id="preview"
class="w-full h-40 object-cover rounded-lg border shadow-sm">
</div>

<hr class="border-gray-200">

<!-- SUBMIT -->
<button id="btn"
class="w-full py-3 rounded-lg text-white font-medium
bg-indigo-600 hover:bg-indigo-700
transition shadow-sm">
Add Item
</button>

<p class="text-xs text-gray-400 text-center">
💡 Fair pricing = faster sales • 🔒 Meet safely in campus
</p>

</form>
</div>
</div>

<script>
const category = document.getElementById("category");
const customBox = document.getElementById("customBox");
const customInput = document.getElementById("customCategory");

const imgInput = document.getElementById("imgInput");
const cameraInput = document.getElementById("cameraInput");
const preview = document.getElementById("preview");
const previewBox = document.getElementById("previewBox");

const form = document.getElementById("form");
const btn = document.getElementById("btn");
const priceHint = document.getElementById("priceHint");

// PRICE HINT
function updatePriceHint() {
    const val = category.value;

    if (val === "Notes") priceHint.innerText = "💡 ₹5 – ₹50 recommended";
    else if (val === "Books") priceHint.innerText = "💡 ₹50 – ₹300";
    else if (val === "Electronics") priceHint.innerText = "💡 Based on condition";
    else if (val === "Item-Set") priceHint.innerText = "💡 Bundle for better value";
    else priceHint.innerText = "💡 Keep price reasonable";
}

category.onchange = () => {
    customBox.classList.toggle("hidden", category.value !== "Other");
    updatePriceHint();
};

updatePriceHint();

// IMAGE PREVIEW
function showPreview(file){
    if (!file) return;
    preview.src = URL.createObjectURL(file);
    previewBox.classList.remove("hidden");
}

imgInput.onchange = e => showPreview(e.target.files[0]);
cameraInput.onchange = e => showPreview(e.target.files[0]);

// MESSAGE
function showMsg(message, success = true) {
    const box = document.getElementById("msgBox");

    box.innerText = message;
    box.classList.remove("hidden");

    box.className = `mb-4 p-3 rounded-xl text-sm ${
        success ? "bg-green-100 text-green-700" : "bg-red-100 text-red-700"
    }`;

    setTimeout(() => box.classList.add("hidden"), 3000);
}

// SUBMIT VALIDATION
form.onsubmit = (e) => {

    const name = form.name.value.trim();
    const price = Number(form.price.value);

    if (!name || !price) {
        showMsg("Please fill all fields", false);
        e.preventDefault();
        return;
    }

    if (price <= 0 || price > 2000) {
        showMsg("Price must be ₹1–₹2000", false);
        e.preventDefault();
        return;
    }

    if (category.value === "Notes" && price > 50) {
        showMsg("Notes should be below ₹50", false);
        e.preventDefault();
        return;
    }

    if (category.value === "Other" && customInput.value.trim()) {
        category.value = customInput.value;
    }

    btn.innerHTML = `
    <span class="flex items-center justify-center gap-2">
      <span class="w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin"></span>
      Uploading...
    </span>`;
    btn.disabled = true;
};

// SMOOTH SCROLL FIX
document.querySelectorAll("input, textarea, select").forEach(el => {
    el.addEventListener("focus", () => {
        setTimeout(() => {
            window.scrollTo({
                top: el.getBoundingClientRect().top + window.scrollY - 120,
                behavior: "smooth"
            });
        }, 200);
    });
});
</script>

</body>
</html>