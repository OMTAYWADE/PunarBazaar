<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Dashboard</title>

<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

<style>
html { scroll-behavior: smooth; }

/* smooth fade */
@keyframes fadeUp {
  from { opacity:0; transform: translateY(15px); }
  to { opacity:1; transform: translateY(0); }
}
.animate-fadeUp {
  animation: fadeUp 0.5s ease forwards;
}

/* tab fade */
.tab-section {
  animation: fadeUp 0.4s ease;
}
</style>
</head>

<body class="bg-gradient-to-br from-slate-100 via-indigo-50 to-slate-200 min-h-screen">

<div class="max-w-7xl mx-auto px-4 py-8">

<!-- HEADER -->
<div class="flex justify-between items-center mb-6 animate-fadeUp">
    <div>
        <h1 class="text-2xl font-bold text-indigo-600">Dashboard</h1>
        <p class="text-sm text-gray-500">Manage everything here</p>
    </div>

    <a href="/" class="text-sm px-4 py-1.5 rounded-lg bg-white shadow hover:bg-gray-100 transition">
        ← Home
    </a>
</div>

<!-- TOGGLE -->
<div class="flex gap-2 mb-6 bg-white/60 backdrop-blur p-2 rounded-xl shadow w-fit animate-fadeUp">

<button onclick="switchTab(event,'purchases')" 
class="tab-btn px-4 py-1.5 rounded-lg text-sm bg-indigo-600 text-white">
Purchases
</button>

<button onclick="switchTab(event,'sales')" 
class="tab-btn px-4 py-1.5 rounded-lg text-sm text-gray-600 hover:bg-gray-100">
Listings
</button>

<button onclick="switchTab(event,'orders')" 
class="tab-btn px-4 py-1.5 rounded-lg text-sm text-gray-600 hover:bg-gray-100">
Book Orders
</button>

</div>

<!-- ================= PURCHASES ================= -->
<div id="purchasesSection" class="tab-section">

<% if(purchases.length === 0){ %>
<div class="text-center py-10 text-gray-500">
    No purchases yet 🚀
</div>
<% } %>

<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-5">

<% purchases.forEach((p,i) => { %>

<div class="bg-white/80 backdrop-blur rounded-2xl shadow hover:shadow-xl transition overflow-hidden group animate-fadeUp"
style="animation-delay:<%= i * 0.05 %>s">

<div class="h-36 bg-gray-200 overflow-hidden">
<% if(p.item?.image){ %>
<img src="<%= p.item.image %>" class="w-full h-full object-cover group-hover:scale-105 transition">
<% } %>
</div>

<div class="p-3">
<h3 class="text-sm font-semibold truncate"><%= p.item?.name %></h3>
<p class="text-green-600 font-bold text-sm">₹ <%= p.item?.price %></p>

<a href="/item/<%= p.item?._id %>"
class="block mt-2 text-center bg-indigo-600 text-white py-1.5 rounded-lg text-xs hover:bg-indigo-700 transition">
View
</a>
</div>

</div>

<% }) %>
</div>

</div>

<!-- ================= SALES ================= -->
<div id="salesSection" class="tab-section hidden">

<% if(sales.length === 0){ %>
<div class="text-center py-10 text-gray-500">
    No listings yet 📦
</div>
<% } %>

<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-5">

<% sales.forEach((item,i) => { %>

<div class="bg-white/80 backdrop-blur rounded-2xl shadow hover:shadow-xl transition overflow-hidden group animate-fadeUp"
style="animation-delay:<%= i * 0.05 %>s">

<div class="h-36 bg-gray-200 overflow-hidden">
<% if(item.image){ %>
<img src="<%= item.image %>" class="w-full h-full object-cover group-hover:scale-105 transition">
<% } %>
</div>

<div class="p-3">
<h3 class="text-sm font-semibold truncate"><%= item.name %></h3>
<p class="text-green-600 font-bold text-sm">₹ <%= item.price %></p>

<a href="/item/<%= item._id %>"
class="block mt-2 text-center bg-indigo-600 text-white py-1.5 rounded-lg text-xs hover:bg-indigo-700 transition">
Manage
</a>
</div>

</div>

<% }) %>
</div>

</div>

<!-- ================= BOOK ORDERS ================= -->
<div id="ordersSection" class="tab-section hidden">

<% if(bookOrders.length === 0){ %>
<div class="text-center py-10 text-gray-500">
    No book orders yet 📄
</div>
<% } %>

<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-5">

<% bookOrders.forEach((o,i) => { %>

<div class="bg-white/80 backdrop-blur rounded-2xl shadow p-4 hover:shadow-xl transition animate-fadeUp"
style="animation-delay:<%= i * 0.05 %>s">

<p class="font-semibold text-sm"><%= o.book?.name %></p>
<p class="text-xs text-gray-500">Buyer: <%= o.buyer?.name %></p>
<p class="text-xs text-gray-500">Qty: <%= o.quantity %></p>

<p class="text-xs mt-2">
Status:
<span class="font-medium 
<%= o.status === 'ready' ? 'text-green-600' : 'text-indigo-600' %>">
<%= o.status %>
</span>
</p>

<% if(o.status !== "ready"){ %>
<button onclick="notifyBuyer('<%= o._id %>')"
class="mt-3 w-full py-2 bg-indigo-600 text-white rounded-lg text-xs hover:bg-indigo-700 transition">
Mark Ready & Notify
</button>
<% } else { %>
<p class="text-green-600 text-xs mt-2">✔ Buyer notified</p>
<% } %>

</div>

<% }) %>

</div>

</div>

</div>

<script>
function switchTab(e, tab){
    document.querySelectorAll(".tab-section").forEach(sec => sec.classList.add("hidden"));
    document.getElementById(tab+"Section").classList.remove("hidden");

    document.querySelectorAll(".tab-btn").forEach(btn=>{
        btn.classList.remove("bg-indigo-600","text-white");
        btn.classList.add("text-gray-600");
    });

    e.target.classList.add("bg-indigo-600","text-white");
}

// notify buyer
async function notifyBuyer(id){
    const res = await fetch(`/book/ready/${id}`, {
        method:"POST",
        credentials:"include"
    });

    const data = await res.json();

    if(data.success){
        window.open(data.waLink, "_blank");
    }
}
</script>

</body>
</html>