<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Dashboard</title>

<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

<style>
html { scroll-behavior: smooth; }

/* smooth entry */
@keyframes fadeUp {
  from { opacity:0; transform: translateY(20px); }
  to { opacity:1; transform: translateY(0); }
}
.animate-fadeUp {
  animation: fadeUp 0.5s ease forwards;
}

/* hide scrollbar */
.no-scrollbar::-webkit-scrollbar {
  display: none;
}
</style>

</head>

<body class="bg-gradient-to-br from-slate-100 via-indigo-50 to-slate-200 min-h-screen">

<div class="max-w-7xl mx-auto px-4 py-8">

<!-- HEADER -->
<div class="flex justify-between items-center mb-8 animate-fadeUp">
    <div>
        <h1 class="text-2xl font-bold text-indigo-600">My Dashboard</h1>
        <p class="text-sm text-gray-500">Manage your activity</p>
    </div>

    <a href="/" class="text-sm text-gray-600 hover:text-indigo-600 transition">
        ← Home
    </a>
</div>

<!-- ================= PURCHASES ================= -->
<div class="mb-10">

<h2 class="text-lg font-semibold mb-4 flex items-center gap-2">
🛒 My Purchases
</h2>

<% if(purchases.length === 0){ %>
<div class="text-center py-10 text-gray-500">
    No purchases yet 🚀
</div>
<% } %>

<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-5">

<% purchases.forEach((p,i) => { %>

<div class="bg-white rounded-2xl shadow-sm hover:shadow-xl transition overflow-hidden group animate-fadeUp"
style="animation-delay:<%= i * 0.05 %>s">

<!-- IMAGE -->
<div class="h-36 bg-gray-200 relative overflow-hidden">

<% if(p.item?.image){ %>
<img src="<%= p.item.image %>"
class="w-full h-full object-cover group-hover:scale-105 transition">
<% } else { %>
<div class="flex items-center justify-center h-full text-gray-400 text-xs">
No Image
</div>
<% } %>

<!-- STATUS -->
<span class="absolute top-2 left-2 bg-green-500 text-white text-[10px] px-2 py-1 rounded-full">
Purchased
</span>

</div>

<!-- CONTENT -->
<div class="p-3">

<h3 class="text-sm font-semibold truncate">
<%= p.item?.name %>
</h3>

<p class="text-green-600 font-bold text-sm">
₹ <%= p.item?.price %>
</p>

<p class="text-xs text-gray-500 truncate">
<%= p.item?.user?.college || "Unknown College" %>
</p>

<a href="/item/<%= p.item?._id %>"
class="block mt-2 text-center bg-indigo-600 text-white py-1.5 rounded-lg text-xs hover:bg-indigo-700 transition">
View Details
</a>

</div>

</div>

<% }) %>

</div>
</div>

<!-- ================= SALES ================= -->
<div>

<h2 class="text-lg font-semibold mb-4 flex items-center gap-2">
📦 My Listings
</h2>

<% if(sales.length === 0){ %>
<div class="text-center py-10 text-gray-500">
    No items listed yet 📦
</div>
<% } %>

<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-5">

<% sales.forEach((item,i) => { %>

<div class="bg-white rounded-2xl shadow-sm hover:shadow-xl transition overflow-hidden group animate-fadeUp"
style="animation-delay:<%= i * 0.05 %>s">

<!-- IMAGE -->
<div class="h-36 bg-gray-200 relative overflow-hidden">

<% if(item.image){ %>
<img src="<%= item.image %>"
class="w-full h-full object-cover group-hover:scale-105 transition">
<% } else { %>
<div class="flex items-center justify-center h-full text-gray-400 text-xs">
No Image
</div>
<% } %>

<!-- STATUS -->
<% if(item.status === "sold"){ %>
<span class="absolute top-2 left-2 bg-red-500 text-white text-[10px] px-2 py-1 rounded-full">
Sold
</span>
<% } else { %>
<span class="absolute top-2 left-2 bg-green-500 text-white text-[10px] px-2 py-1 rounded-full">
Active
</span>
<% } %>

</div>

<!-- CONTENT -->
<div class="p-3">

<h3 class="text-sm font-semibold truncate">
<%= item.name %>
</h3>

<p class="text-green-600 font-bold text-sm">
₹ <%= item.price %>
</p>

<p class="text-xs text-gray-500 truncate">
<%= item.category %>
</p>

<a href="/item/<%= item._id %>"
class="block mt-2 text-center bg-indigo-600 text-white py-1.5 rounded-lg text-xs hover:bg-indigo-700 transition">
Manage Item
</a>

</div>

</div>

<% }) %>

</div>
</div>

</div>

</body>
</html>