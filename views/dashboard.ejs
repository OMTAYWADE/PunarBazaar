<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Dashboard</title>
<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-gradient-to-br from-slate-100 via-indigo-50 to-slate-200 min-h-screen">

<div class="max-w-6xl mx-auto px-4 py-8">

<!-- HEADER -->
<div class="flex justify-between items-center mb-8">
    <h1 class="text-2xl font-bold text-indigo-600">My Dashboard</h1>
    <a href="/" class="text-sm text-gray-600 hover:text-indigo-600">← Home</a>
</div>

<!-- PURCHASES -->
<h2 class="text-lg font-semibold mb-4">🛒 My Purchases</h2>

<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">

<% if(purchases.length === 0){ %>
<p class="text-gray-500">No purchases yet</p>
<% } %>

<% purchases.forEach(p => { %>
<div class="bg-white rounded-xl shadow p-3">

    <h3 class="font-semibold text-sm truncate">
        <%= p.item?.name %>
    </h3>

    <p class="text-green-600 font-bold text-sm">
        ₹ <%= p.item?.price %>
    </p>

    <p class="text-xs text-gray-500">
        Seller: <%= p.item?.user?.name %>
    </p>

    <a href="/item/<%= p.item?._id %>"
    class="block mt-2 text-center bg-indigo-600 text-white py-1 rounded text-xs">
        View
    </a>

</div>
<% }) %>

</div>

<!-- SALES -->
<h2 class="text-lg font-semibold mb-4">📦 My Listings</h2>

<div class="grid grid-cols-2 md:grid-cols-4 gap-4">

<% if(sales.length === 0){ %>
<p class="text-gray-500">No items listed</p>
<% } %>

<% sales.forEach(item => { %>
<div class="bg-white rounded-xl shadow p-3">

    <h3 class="font-semibold text-sm truncate">
        <%= item.name %>
    </h3>

    <p class="text-green-600 font-bold text-sm">
        ₹ <%= item.price %>
    </p>

    <a href="/item/<%= item._id %>"
    class="block mt-2 text-center bg-indigo-600 text-white py-1 rounded text-xs">
        View
    </a>

</div>
<% }) %>

</div>

</div>

</body>
</html>