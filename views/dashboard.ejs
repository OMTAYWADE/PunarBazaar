<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard</title>

<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

<style>
html { scroll-behavior: smooth; }

/* animation */
@keyframes fadeUp {
  from { opacity:0; transform: translateY(10px); }
  to { opacity:1; transform: translateY(0); }
}

.animate-fadeUp {
  animation: fadeUp 0.4s ease;
}

/* FIXED TAB SYSTEM */
.tab-section {
  display: none;
}

.tab-section.active {
  display: block;
  animation: fadeUp 0.3s ease;
}

/* scrollbar hide */
.no-scrollbar::-webkit-scrollbar { display:none; }
.no-scrollbar { scrollbar-width:none; }
</style>
</head>

<body class="bg-gradient-to-br from-slate-100 via-indigo-50 to-slate-200 min-h-screen">

<div class="max-w-7xl mx-auto px-3 sm:px-4 py-6 sm:py-8">

<!-- HEADER -->
<div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-3 mb-6">
    <div>
        <h1 class="text-xl sm:text-2xl font-bold text-indigo-600">Dashboard</h1>
        <p class="text-xs sm:text-sm text-gray-500">Manage everything here</p>
    </div>

    <a href="/" class="text-sm px-4 py-1.5 rounded-lg bg-white shadow hover:bg-gray-100 active:scale-95 transition w-fit">
        ← Home
    </a>
</div>

<!-- TOGGLE -->
<div class="flex overflow-x-auto no-scrollbar gap-2 mb-6 bg-white/70 backdrop-blur p-2 rounded-xl shadow">

<button onclick="switchTab(event,'purchases')" 
class="tab-btn px-4 py-1.5 rounded-lg text-sm whitespace-nowrap bg-indigo-600 text-white active:scale-95">
Purchases
</button>

<button onclick="switchTab(event,'sales')" 
class="tab-btn px-4 py-1.5 rounded-lg text-sm whitespace-nowrap text-gray-600 hover:bg-gray-100 active:scale-95">
Listings
</button>

<button onclick="switchTab(event,'orders')" 
class="tab-btn px-4 py-1.5 rounded-lg text-sm whitespace-nowrap text-gray-600 hover:bg-gray-100 active:scale-95">
Book Orders
</button>

</div>

<!-- ================= PURCHASES ================= -->
<div id="purchasesSection" class="tab-section active">

<% if(!purchases || purchases.length === 0){ %>
<div class="text-center py-10 text-gray-500">No purchases yet 🚀</div>
<% } %>

<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4 sm:gap-5">

<% purchases.forEach((p,i)=>{ %>

<div class="bg-white rounded-2xl shadow hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 overflow-hidden group animate-fadeUp">

<div class="h-28 bg-gray-200 overflow-hidden">
<% if(p.item?.image){ %>
<img src="<%= p.item.image %>" class="w-full h-full object-cover group-hover:scale-110 transition duration-300">
<% } %>
</div>

<div class="p-3">
<h3 class="text-sm font-semibold truncate"><%= p.item?.name %></h3>
<p class="text-green-600 font-bold text-sm">₹ <%= p.item?.price %></p>

<a href="/item/<%= p.item?._id %>"
class="block mt-2 text-center bg-indigo-600 text-white py-2 rounded-lg text-sm hover:bg-indigo-700 transition active:scale-95">
View
</a>
</div>

</div>

<% }) %>
</div>

</div>

<!-- ================= SALES ================= -->
<div id="salesSection" class="tab-section">

<% if(!sales || sales.length === 0){ %>
<div class="text-center py-10 text-gray-500">No listings yet 📦</div>
<% } %>

<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4 sm:gap-5">

<% sales.forEach((item,i)=>{ %>

<div class="bg-white rounded-2xl shadow hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 overflow-hidden group animate-fadeUp">

<div class="h-36 bg-gray-200 overflow-hidden">
<% if(item.image){ %>
<img src="<%= item.image %>" class="w-full h-full object-cover group-hover:scale-110 transition duration-300">
<% } %>
</div>

<div class="p-3">
<h3 class="text-sm font-semibold truncate"><%= item.name %></h3>
<p class="text-green-600 font-bold text-sm">₹ <%= item.price %></p>

<a href="/item/<%= item._id %>"
class="block mt-2 text-center bg-indigo-600 text-white py-2 rounded-lg text-sm hover:bg-indigo-700 transition active:scale-95">
Manage
</a>
</div>

</div>

<% }) %>
</div>

</div>

<!-- ================= BOOK ORDERS ================= -->
<div id="ordersSection" class="tab-section">

<% if(!bookOrders || bookOrders.length === 0){ %>
<div class="text-center py-10 text-gray-500">No book orders yet 📄</div>
<% } %>

<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 sm:gap-5">

<% bookOrders.forEach((o,i)=>{ %>

<div class="bg-white rounded-2xl shadow hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 p-4 animate-fadeUp">

<p class="font-semibold text-sm"><%= o.book?.name %></p>
<p class="text-xs text-gray-500">Buyer: <%= o.buyer?.name %></p>
<p class="text-xs text-gray-500">Qty: <%= o.quantity %></p>

<div class="mt-2">
<span class="px-2 py-1 rounded-full text-xs font-medium
<%= o.status==='ready' ? 'bg-green-100 text-green-600' : 'bg-yellow-100 text-yellow-600' %>">
<%= o.status %>
</span>
</div>

<% if(o.status !== "ready"){ %>
<button onclick="notifyBuyer(event,'<%= o._id %>')"
class="mt-3 w-full py-2 bg-indigo-600 text-white rounded-lg text-sm hover:bg-indigo-700 transition active:scale-95">
Mark Ready & Notify
</button>
<% } else { %>
<p class="text-green-600 text-xs mt-2">✔ Buyer notified</p>
<% } %>

</div>

<% }) %>
</div>

</div>

</div>

<script>
function switchTab(e, tab){
    document.querySelectorAll(".tab-section").forEach(sec=>{
        sec.classList.remove("active");
    });

    document.getElementById(tab+"Section").classList.add("active");

    document.querySelectorAll(".tab-btn").forEach(btn=>{
        btn.classList.remove("bg-indigo-600","text-white");
        btn.classList.add("text-gray-600");
    });

    e.target.classList.add("bg-indigo-600","text-white");
}

async function notifyBuyer(e, id){
    const btn = e.target;
    btn.innerText = "Processing...";
    btn.disabled = true;

    const res = await fetch(`/book/ready/${id}`, {
        method:"POST",
        credentials:"include"
    });

    const data = await res.json();

    if(data.success){
        window.open(data.waLink, "_blank");
        btn.innerText = "Done";
    } else {
        btn.innerText = "Error";
    }
}
</script>

</body>
</html>